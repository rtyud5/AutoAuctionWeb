<!-- profile.html -->
<div class="p-10 w-full font-inter">

    <div class="border-2 border-[#BEEAFF] rounded-2xl p-6 bg-gradient-to-r from-[#ECF4FB] to-[#FFF8EB]">

        <!-- Header -->
        <div class="flex items-center gap-4 mb-6">
            <img src="https://i.ibb.co/2Pn7gG6/user.jpg"
                 class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-lg">

            <div>
                <h3 class="text-lg font-semibold">Alexa Rawles</h3>
                <p class="text-gray-500 text-sm">alexarawles@gmail.com</p>
            </div>
        </div>

        <!-- Basic Info -->
        <div class="bg-[#EAF2FF] p-6 rounded-xl mb-6">
            <div class="grid grid-cols-2 gap-6 mb-4">

                <div class="flex flex-col gap-1">
                    <label class="text-sm text-gray-700">Full Name</label>
                    <input type="text"
                           class="bg-[#F9FAFC] h-10 rounded-md px-3 outline-none"
                           value="Alexa Rawles">
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-sm text-gray-700">Email address</label>
                    <input type="text"
                           class="bg-[#F9FAFC] h-10 rounded-md px-3 outline-none"
                           value="alexarawles@gmail.com">
                </div>

            </div>

            <button class="float-right bg-[#4D8BFF] text-white py-2 px-4 rounded-lg">
                Save change
            </button>

            <div class="clear-both"></div>
        </div>

        <!-- Password Section -->
        <div class="bg-[#EAF2FF] p-6 rounded-xl">
            <div class="grid grid-cols-3 gap-6 mb-4">

                <div class="flex flex-col gap-1">
                    <label class="text-sm text-gray-700">Current password</label>
                    <input type="password"
                           placeholder="••••••"
                           class="bg-[#F9FAFC] h-10 rounded-md px-3 outline-none">
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-sm text-gray-700">New password</label>
                    <input type="password"
                           placeholder="••••••"
                           class="bg-[#F9FAFC] h-10 rounded-md px-3 outline-none">
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-sm text-gray-700">Confirm new password</label>
                    <input type="password"
                           placeholder="••••••"
                           class="bg-[#F9FAFC] h-10 rounded-md px-3 outline-none">
                </div>

            </div>

            <button class="float-right bg-[#4D8BFF] text-white py-2 px-4 rounded-lg">
                Save change
            </button>

            <div class="clear-both"></div>
        </div>

    </div>
</div>
