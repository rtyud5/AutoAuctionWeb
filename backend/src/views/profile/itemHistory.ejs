<%
  const fmtMoney = (v) => {
    const n = Number(v);
    if (!Number.isFinite(n)) return '-';
    return new Intl.NumberFormat('vi-VN').format(n) + ' VNĐ';
  };
  const fmtTime = (v) => {
    try { return new Date(v).toLocaleString('vi-VN'); } catch (e) { return ''; }
  };
  const renderText = (e) => {
    const title = e?.title || 'Sản phẩm';
    const amount = fmtMoney(e?.amount);
    switch (e?.kind) {
      case 'AUTO_BID':
        return `Autobid ${title} giá ${amount}` + (e.is_update ? ' (cập nhật autobid)' : '');
      case 'BUY_NOW':
        return `Mua ngay ${title} giá ${amount}`;
      case 'WIN':
        return `Thắng bid ${title} giá ${amount}`;
      case 'LOSE':
        return `Thua bid ${title}` + (Number(e?.amount) ? ` (giá chốt ${amount})` : '');
      case 'BID':
      default:
        return `Bid ${title} giá ${amount}`;
    }
  };
%>

<div class="p-10 w-full font-inter">
  <div class="border-2 border-[#BEEAFF] rounded-2xl p-6 bg-gradient-to-r from-[#ECF4FB] to-[#FFF8EB]">
    <div class="flex items-center justify-between gap-3 mb-6">
      <h2 class="text-xl font-semibold text-slate-900">Lịch sử đấu giá</h2>
      <div class="text-xs text-slate-600">
        Hiển thị theo timeline thời gian (mới nhất ở dưới)
      </div>
    </div>

    <div class="bg-white/70 border border-slate-200 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-slate-600 bg-slate-50/70">
            <tr class="border-b border-slate-200">
              <th class="text-left font-medium py-3 px-4 whitespace-nowrap">Thời gian</th>
              <th class="text-left font-medium py-3 px-4">Hoạt động</th>
              <th class="text-center font-medium py-3 px-4 whitespace-nowrap">Loại</th>
            </tr>
          </thead>
          <tbody>
            <% if (!events || events.length === 0) { %>
              <tr>
                <td colspan="3" class="py-6 px-4 text-slate-500">Chưa có lịch sử bid / mua ngay / kết quả đấu giá.</td>
              </tr>
            <% } else { %>
              <% events.forEach(function(e) { %>
                <tr class="border-b border-slate-100">
                  <td class="py-3 px-4 whitespace-nowrap text-slate-600"><%= fmtTime(e.at) %></td>
                  <td class="py-3 px-4 text-slate-900"><%= renderText(e) %></td>
                  <td class="py-3 px-4 text-center">
                    <% if (e.kind === 'WIN') { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-600 text-white">Thắng</span>
                    <% } else if (e.kind === 'LOSE') { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-rose-600 text-white">Thua</span>
                    <% } else if (e.kind === 'BUY_NOW') { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-sky-600 text-white">Mua ngay</span>
                    <% } else if (e.kind === 'AUTO_BID') { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-600 text-white">Autobid</span>
                    <% } else { %>
                      <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-700 text-white">Bid</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
