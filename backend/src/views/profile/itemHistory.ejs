
<body class="bg-gradient-to-br from-blue-50 to-purple-50 min-h-screen">
    <!-- Header -->
    <%- include('partials/header') %>

    <div class="flex min-h-[calc(100vh-80px)]">
        <!-- Sidebar -->
        <%- include('partials/sidebar') %>

        <!-- Main Content -->
        <main class="flex-1 p-8 space-y-8">
            
            <!-- Sản Phẩm Yêu Thích -->
            <section class="bg-gradient-to-br from-blue-100/50 to-purple-100/40 rounded-3xl p-6 shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800 mb-6">Sản Phẩm Yêu Thích</h2>
                
                <!-- Product Item -->
                <% if (favoriteProducts && favoriteProducts.length > 0) { %>
                    <% favoriteProducts.forEach(product => { %>
                        <div class="bg-white/80 rounded-2xl p-4 mb-4 flex items-center justify-between hover:shadow-md transition">
                            <div class="flex items-center gap-4">
                                <div class="w-16 h-16 bg-gray-200 rounded-lg overflow-hidden flex-shrink-0">
                                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <h3 class="font-medium text-gray-800"><%= product.name %></h3>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <span class="text-lg font-semibold text-gray-800"><%= product.price.toLocaleString() %> VNĐ</span>
                                <button class="w-10 h-10 bg-red-500 hover:bg-red-600 rounded-lg flex items-center justify-center transition shadow-md">
                                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">Chưa có sản phẩm yêu thích</p>
                <% } %>

                <!-- Pagination -->
                <div class="flex justify-center items-center gap-2 mt-6">
                    <button class="w-8 h-8 bg-gray-800 text-white rounded-full flex items-center justify-center hover:bg-gray-700 transition">1</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">2</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">3</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </div>
            </section>

            <!-- Sản phẩm đang đấu giá -->
            <section class="bg-gradient-to-br from-blue-100/50 to-purple-100/40 rounded-3xl p-6 shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800 mb-6">Sản phẩm đang đấu giá</h2>
                
                <% if (auctionProducts && auctionProducts.length > 0) { %>
                    <% auctionProducts.forEach(product => { %>
                        <div class="bg-white/80 rounded-2xl p-4 mb-4 flex items-center justify-between hover:shadow-md transition">
                            <div class="flex items-center gap-4">
                                <div class="w-16 h-16 bg-gray-200 rounded-lg overflow-hidden flex-shrink-0">
                                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <h3 class="font-medium text-gray-800"><%= product.name %></h3>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <span class="text-lg font-semibold text-gray-800"><%= product.price.toLocaleString() %> VNĐ</span>
                                <span class="px-4 py-2 bg-green-500 text-white rounded-lg font-medium text-sm shadow-md">
                                    Đang hoạt động
                                </span>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">Chưa có sản phẩm đang đấu giá</p>
                <% } %>

                <!-- Pagination -->
                <div class="flex justify-center items-center gap-2 mt-6">
                    <button class="w-8 h-8 bg-gray-800 text-white rounded-full flex items-center justify-center hover:bg-gray-700 transition">1</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">2</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">3</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </div>
            </section>

            <!-- Sản phẩm đã thắng -->
            <section class="bg-gradient-to-br from-blue-100/50 to-purple-100/40 rounded-3xl p-6 shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800 mb-6">Sản phẩm đã thắng</h2>
                
                <% if (wonProducts && wonProducts.length > 0) { %>
                    <% wonProducts.forEach(product => { %>
                        <div class="bg-white/80 rounded-2xl p-4 mb-4 flex items-center justify-between hover:shadow-md transition">
                            <div class="flex items-center gap-4">
                                <div class="w-16 h-16 bg-gray-200 rounded-lg overflow-hidden flex-shrink-0">
                                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <h3 class="font-medium text-gray-800"><%= product.name %></h3>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <span class="text-lg font-semibold text-gray-800"><%= product.price.toLocaleString() %> VNĐ</span>
                                <span class="text-sm text-gray-600"><%= product.wonDate %></span>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">Chưa có sản phẩm đã thắng</p>
                <% } %>

                <!-- Pagination -->
                <div class="flex justify-center items-center gap-2 mt-6">
                    <button class="w-8 h-8 bg-gray-800 text-white rounded-full flex items-center justify-center hover:bg-gray-700 transition">1</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">2</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">3</button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </div>
            </section>

        </main>
    </div>
</body>
</html>