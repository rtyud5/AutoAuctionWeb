<div class="w-full min-h-screen bg-gradient-to-b from-blue-50 to-white p-6">

    <!-- SECTION 1 — Sản phẩm đang đấu giá -->
    <section class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 mb-10">
        <h2 class="text-lg font-semibold text-gray-700 mb-4">
            danh sách sản phẩm đang đóng & còn hạn
        </h2>

        <table class="w-full text-sm text-gray-700">
            <thead class="font-semibold border-b">
                <tr>
                    <th class="py-2 text-left">Sản Phẩm</th>
                    <th class="py-2 text-left">Giá hiện tại</th>
                    <th class="py-2 text-left">Giá thầu</th>
                    <th class="py-2 text-left">Thời gian</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                <tr class="border-b">
                    <td class="py-3 flex items-center gap-3">
                        <img src="https://via.placeholder.com/50" class="w-12 h-12 rounded-lg">
                        sMasy tĩnh
                    </td>
                    <td class="py-3">3.000.000 VNĐ</td>
                    <td class="py-3">12</td>
                    <td class="py-3">2d 4h 30m</td>
                    <td class="py-3 text-blue-500 cursor-pointer hover:underline">xem chi tiết</td>
                </tr>
            </tbody>
        </table>

        <p class="text-red-500 font-semibold mt-3">Kết thúc sau: 1h 30m</p>

        <!-- Pagination -->
        <div class="flex items-center gap-3 justify-center mt-6 text-gray-700">
            <span class="px-3 py-1 rounded-full bg-gray-900 text-white font-semibold cursor-pointer">1</span>
            <span class="px-3 py-1 rounded-full cursor-pointer hover:bg-gray-200">2</span>
            <span class="px-3 py-1 rounded-full cursor-pointer hover:bg-gray-200">3</span>
            <span class="px-3 py-1 rounded-full cursor-pointer hover:bg-gray-200">→</span>
        </div>
    </section>

    <!-- SECTION 2 — Sản phẩm đã có người thắng -->
    <section class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-700 mb-4">
            danh sách sản phẩm đã có người thắng đấu giá
        </h2>

        <!-- Item -->
        <div class="bg-gray-50 p-4 rounded-xl shadow-sm flex items-center justify-between">
            <div class="flex items-center gap-4">
                <img src="https://via.placeholder.com/60" class="w-14 h-14 rounded-lg">
                <div>
                    <p class="font-medium">sMasy tĩnh</p>
                    <p class="text-sm text-gray-500">Seller_Alex</p>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <span class="font-semibold text-gray-900">3.000.000 VNĐ</span>

                <div class="flex items-center gap-1">
                    <button class="bg-green-100 text-green-600 px-2 rounded-lg font-bold">👍+1</button>
                    <button class="bg-red-100 text-red-600 px-2 rounded-lg font-bold">👎-1</button>
                </div>
            </div>
        </div>

        <!-- Comment box -->
        <div class="mt-4">
            <textarea
                class="w-full h-40 bg-blue-100 rounded-xl p-4 outline-none"
                placeholder="Type your comment here ..."
            ></textarea>

            <button class="mt-2 bg-gray-900 text-white px-6 py-2 rounded-lg shadow hover:bg-gray-800">
                Submit
            </button>

            <button class="mt-4 bg-red-500 text-white px-6 py-2 rounded-lg block mx-auto hover:bg-red-600">
                Hủy giao dịch
            </button>
        </div>

        <!-- Pagination -->
        <div class="flex items-center gap-3 justify-center mt-6 text-gray-700">
            <span class="px-3 py-1 rounded-full bg-gray-900 text-white font-semibold cursor-pointer">1</span>
            <span class="px-3 py-1 rounded-full cursor-pointer hover:bg-gray-200">2</span>
            <span class="px-3 py-1 rounded-full cursor-pointer hover:bg-gray-200">3</span>
            <span class="px-3 py-1 rounded-full cursor-pointer hover:bg-gray-200">→</span>
        </div>
    </section>
</div>
