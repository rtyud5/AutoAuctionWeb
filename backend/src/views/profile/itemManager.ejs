<% layout('layouts/main') %>

<div class="w-full min-h-screen bg-gradient-to-b from-blue-50 to-white p-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold text-slate-800">Quản lý sản phẩm</h1>
      <a href="/seller/products/new" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        <i class="fas fa-plus"></i> Đăng sản phẩm mới
      </a>
    </div>

    <% if (products && products.length > 0) { %>
      <section class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 mb-10">
        <h2 class="text-lg font-semibold text-gray-700 mb-4">Danh sách sản phẩm của bạn</h2>

        <table class="w-full text-sm text-gray-700">
          <thead class="font-semibold border-b">
            <tr>
              <th class="py-2 text-left">Sản phẩm</th>
              <th class="py-2 text-left">Danh mục</th>
              <th class="py-2 text-left">Trạng thái</th>
              <th class="py-2 text-left">Ngày tạo</th>
              <th class="py-2 text-left">Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(p => { %>
              <tr class="border-b">
                <td class="py-3 flex items-center gap-3">
                  <img src="<%= p.thumbnail || '/images/placeholder.jpg' %>" class="w-12 h-12 rounded-lg object-cover border">
                  <div>
                    <div class="font-medium"><%= p.title %></div>
                    <div class="text-xs text-gray-500 line-clamp-1"><%= p.short_description || 'Không có mô tả' %></div>
                  </div>
                </td>
                <td class="py-3"><%= p.category_name || '—' %></td>
                <td class="py-3">
                  <span class="px-2 py-1 rounded text-xs
                    <%= p.status === 'APPROVED' ? 'bg-green-100 text-green-700' :
                        p.status === 'PENDING' ? 'bg-yellow-100 text-yellow-700' :
                        p.status === 'SOLD' ? 'bg-blue-100 text-blue-700' :
                        'bg-gray-100 text-gray-700' %>">
                    <%= p.status %>
                  </span>
                </td>
                <td class="py-3"><%= p.created_at ? new Date(p.created_at).toLocaleString() : '—' %></td>
                <td class="py-3">
                  <div class="flex items-center gap-3">
                    <a href="/seller/products/<%= p.id %>/edit" class="text-blue-600 hover:underline">
                      <i class="fas fa-edit"></i> Sửa
                    </a>
                    <button onclick="deleteProduct(<%= p.id %>)" class="text-red-600 hover:underline">
                      <i class="fas fa-trash"></i> Xóa
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    <% } else { %>
      <section class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-700 mb-4">Danh sách sản phẩm</h2>
        <div class="text-center py-12 bg-slate-50 rounded-lg">
          <p class="text-slate-600 mb-4">Chưa có sản phẩm nào</p>
          <a href="/seller/products/new" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Đăng sản phẩm đầu tiên</a>
        </div>
      </section>
    <% } %>
  </div>
</div>

<script>
  async function deleteProduct(id) {
    if (!confirm('Bạn có chắc muốn xóa sản phẩm này?')) return;
    try {
      const res = await fetch(`/seller/products/${id}`, { method: 'DELETE', credentials: 'include' });
      const result = await res.json();
      if (result.success) {
        alert('✅ Xóa sản phẩm thành công');
        window.location.reload();
      } else {
        alert('❌ ' + (result.message || 'Có lỗi xảy ra'));
      }
    } catch (err) {
      console.error(err);
      alert('❌ Có lỗi xảy ra');
    }
  }
</script>