<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Reviews</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 to-purple-50 min-h-screen">
    <!-- Header -->
    <%- include('partials/header') %>

    <div class="flex min-h-[calc(100vh-80px)]">
        <!-- Sidebar -->
        <%- include('partials/sidebar') %>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            
            <!-- My Review Section -->
            <section class="bg-gradient-to-br from-blue-100/50 to-purple-100/40 rounded-3xl p-6 shadow-lg">
                <h2 class="text-xl font-semibold text-gray-800 mb-6">My review</h2>
                
                <!-- Overall Rating -->
                <div class="mb-6">
                    <div class="flex items-center gap-2">
                        <span class="text-gray-700 font-medium">Overall rating:</span>
                        <div class="flex items-center gap-1">
                            <span class="text-green-600 font-bold text-lg">+52</span>
                            <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z" />
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Reviews List -->
                <div class="space-y-4">
                    <% if (reviews && reviews.length > 0) { %>
                        <% reviews.forEach(review => { %>
                            <div class="bg-white/80 rounded-2xl p-5 hover:shadow-md transition">
                                <div class="flex items-start justify-between">
                                    <div class="flex items-start gap-4 flex-1">
                                        <!-- Avatar -->
                                        <div class="w-12 h-12 rounded-full overflow-hidden flex-shrink-0 border-2 border-gray-200">
                                            <img src="<%= review.avatar %>" alt="<%= review.username %>" class="w-full h-full object-cover">
                                        </div>
                                        
                                        <!-- Review Content -->
                                        <div class="flex-1">
                                            <h3 class="font-semibold text-gray-800 mb-1"><%= review.username %></h3>
                                            <p class="text-gray-600 text-sm leading-relaxed">"<%= review.comment %>"</p>
                                        </div>
                                    </div>

                                    <!-- Rating Badge -->
                                    <div class="flex-shrink-0 ml-4">
                                        <% if (review.rating > 0) { %>
                                            <div class="flex items-center gap-2 bg-green-500 text-white px-4 py-2 rounded-lg shadow-md">
                                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                                    <path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z" />
                                                </svg>
                                                <span class="font-bold">+<%= review.rating %></span>
                                            </div>
                                        <% } else { %>
                                            <div class="flex items-center gap-2 bg-red-500 text-white px-4 py-2 rounded-lg shadow-md">
                                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                                    <path d="M18 9.5a1.5 1.5 0 11-3 0v-6a1.5 1.5 0 013 0v6zM14 9.667v-5.43a2 2 0 00-1.105-1.79l-.05-.025A4 4 0 0011.055 2H5.64a2 2 0 00-1.962 1.608l-1.2 6A2 2 0 004.44 12H8v4a2 2 0 002 2 1 1 0 001-1v-.667a4 4 0 01.8-2.4l1.4-1.866a4 4 0 00.8-2.4z" />
                                                </svg>
                                                <span class="font-bold"><%= review.rating %></span>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-gray-500 text-center py-12">Chưa có đánh giá nào</p>
                    <% } %>
                </div>

                <!-- Pagination -->
                <div class="flex justify-center items-center gap-2 mt-8">
                    <button class="w-8 h-8 bg-gray-800 text-white rounded-full flex items-center justify-center hover:bg-gray-700 transition text-sm font-medium">
                        1
                    </button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition text-sm font-medium">
                        2
                    </button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition text-sm font-medium">
                        3
                    </button>
                    <button class="w-8 h-8 bg-white text-gray-800 rounded-full flex items-center justify-center hover:bg-gray-100 transition">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                </div>
            </section>

        </main>
    </div>
</body>
</html>