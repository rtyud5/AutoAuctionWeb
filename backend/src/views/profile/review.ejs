<div class="flex font-inter">

    <!-- Content -->
    <div class="flex-1 p-10">

        <div class="border-2 border-[#BEEAFF] rounded-2xl p-6 bg-[#E8F0FE]">

            <h2 class="text-xl font-semibold mb-4">My review</h2>

            <!-- Overall Rating -->
            <div class="bg-[#D9DEE6] p-4 rounded-xl mb-6 flex items-center gap-3">
                <span class="text-gray-700 font-medium">Overall rating:</span>
                <span class="text-green-600 font-bold text-lg">+52</span>
            </div>

            <!-- Review Item -->
            <div class="mb-6">
                <div class="flex items-start justify-between">

                    <!-- Avatar + Info -->
                    <div class="flex items-center gap-3">
                        <img src="https://i.ibb.co/2Pn7gG6/user.jpg"
                             class="w-12 h-12 rounded-full object-cover border" />

                        <div>
                            <p class="font-semibold">Seller_Alex</p>
                            <p class="text-gray-600 text-sm">“Good”</p>
                        </div>
                    </div>

                    <!-- Rating -->
                    <div class="flex items-center gap-2 bg-green-500 text-white px-3 py-1 rounded-full">
                        <span class="text-xl">👍</span>
                        <span>+1</span>
                    </div>
                </div>

                <div class="border-b my-4"></div>
            </div>

            <!-- Review Item 2 -->
            <div class="mb-6">
                <div class="flex items-start justify-between">

                    <div class="flex items-center gap-3">
                        <img src="https://i.ibb.co/2Pn7gG6/user.jpg"
                             class="w-12 h-12 rounded-full object-cover border" />

                        <div>
                            <p class="font-semibold">Seller_Alex</p>
                            <p class="text-gray-600 text-sm">“Bad”</p>
                        </div>
                    </div>

                    <!-- Negative -->
                    <div class="flex items-center gap-2 bg-red-500 text-white px-3 py-1 rounded-full">
                        <span class="text-xl">👎</span>
                        <span>-1</span>
                    </div>

                </div>

                <div class="border-b my-4"></div>
            </div>

            <!-- Pagination -->
            <div class="flex justify-center mt-8 gap-4">

                <button class="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center">
                    1
                </button>

                <button class="text-gray-600 hover:text-black">2</button>
                <button class="text-gray-600 hover:text-black">3</button>

                <button class="text-gray-600 hover:text-black text-xl">→</button>
            </div>

        </div>
    </div>

</div>
