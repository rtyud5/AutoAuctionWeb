<div class="min-h-screen bg-white text-slate-900">
  <div class="mx-auto max-w-3xl px-4 py-10 space-y-8">
    <!-- Tiêu đề -->
    <div class="space-y-2">
      <p class="text-sm text-slate-500">Nâng cấp tài khoản</p>
      <h1 class="text-3xl font-semibold">Yêu cầu trở thành Seller</h1>
      <p class="text-sm text-slate-500">
        Hãy cho chúng tôi biết lý do bạn muốn nâng cấp để được duyệt nhanh hơn.
      </p>
    </div>

    <!-- Thông báo (nếu dùng flash message) -->
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="rounded-lg border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-3 text-sm">
        <%= success %>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3 text-sm">
        <%= error %>
      </div>
    <% } %>

    <!-- Form gửi yêu cầu -->
    <form
      method="POST"
      action="/me/upgrade-request"
      class="space-y-5 bg-white border border-slate-200 rounded-2xl p-6 shadow-lg shadow-slate-200/60"
    >
      <div class="space-y-2">
        <label for="message" class="block text-sm font-medium text-slate-800">
          Lý do / Ghi chú
        </label>
        <textarea
          id="message"
          name="message"
          required
          class="w-full rounded-xl bg-white border border-slate-300 focus:border-teal-500 focus:ring-2 focus:ring-teal-200 text-sm text-slate-900 placeholder:text-slate-400 px-3 py-2"
        ></textarea>
      </div>

      <div class="flex items-center gap-3">
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-xl bg-teal-600 hover:bg-teal-500 px-4 py-2.5 text-sm font-semibold text-white shadow-md shadow-teal-200/60 transition"
        >
          Gửi yêu cầu nâng cấp
        </button>
        <a
          href="/"
          class="text-sm text-slate-500 hover:text-slate-700 transition"
        >
          ← Quay về trang chủ
        </a>
      </div>
    </form>

    <div class="text-xs text-slate-500">
      Lưu ý: Yêu cầu sẽ được admin xem xét và phê duyệt. Bạn sẽ nhận thông báo khi trạng thái thay đổi.
    </div>
  </div>
</div>