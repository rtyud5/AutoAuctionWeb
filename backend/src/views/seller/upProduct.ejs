<% layout('layouts/main') %>

<div class="max-w-5xl mx-auto px-4 py-10">
  <div class="bg-white shadow-xl rounded-2xl border border-slate-100 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-500 to-indigo-500 text-white px-6 py-4 flex items-center gap-2">
      <i class="fas fa-box text-lg"></i>
      <h2 class="text-lg font-semibold">Đăng sản phẩm mới</h2>
    </div>

    <form id="productForm" enctype="multipart/form-data" class="p-6 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <!-- Tên sản phẩm -->
        <div class="md:col-span-2">
          <label for="title" class="block text-sm font-semibold text-slate-700 mb-1">
            Tên sản phẩm <span class="text-rose-500">*</span>
          </label>
          <input id="title" name="title" type="text" required
                 class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                 placeholder="Nhập tên sản phẩm">
        </div>

        <!-- Danh mục -->
        <div>
          <label for="category_id" class="block text-sm font-semibold text-slate-700 mb-1">
            Danh mục <span class="text-rose-500">*</span>
          </label>
          <select id="category_id" name="category_id" required
                  class="w-full rounded-lg border border-slate-200 px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent">
            <option value="">-- Chọn danh mục --</option>
            <% (categories || []).forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <!-- Mô tả ngắn -->
        <div>
          <label for="short_description" class="block text-sm font-semibold text-slate-700 mb-1">
            Mô tả ngắn
          </label>
          <textarea id="short_description" name="short_description" rows="3" maxlength="500"
                    class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                    placeholder="Mô tả ngắn gọn (tối đa 500 ký tự)"></textarea>
          <div class="flex items-center justify-between mt-1 text-xs text-slate-500">
            <span>Tối đa 500 ký tự</span>
            <span><span id="shortDescCount">0</span>/500</span>
          </div>
        </div>
      </div>

      <!-- Mô tả chi tiết -->
      <div>
        <label for="full_description" class="block text-sm font-semibold text-slate-700 mb-1">
          Mô tả chi tiết
        </label>
        <textarea id="full_description" name="full_description" rows="5"
                  class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                  placeholder="Mô tả chi tiết về sản phẩm, tình trạng, nguồn gốc..."></textarea>
      </div>

      <!-- Thông tin phiên đấu giá -->
      <div class="border-t pt-6">
        <h3 class="text-md font-semibold text-slate-700 mb-4">Thông tin phiên đấu giá</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <!-- Giá khởi điểm -->
          <div>
            <label for="starting_price" class="block text-sm font-semibold text-slate-700 mb-1">
              Giá khởi điểm (VNĐ) <span class="text-rose-500">*</span>
            </label>
            <input id="starting_price" name="starting_price" type="number" min="0" step="1000" required
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                   placeholder="Ví dụ: 1000000">
          </div>

          <!-- Bước giá -->
          <div>
            <label for="step_price" class="block text-sm font-semibold text-slate-700 mb-1">
              Bước giá (VNĐ)
            </label>
            <input id="step_price" name="step_price" type="number" min="0" step="1000" value="100000"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                   placeholder="Mặc định: 100000">
            <p class="mt-1 text-xs text-slate-500">Mặc định 100.000 VNĐ nếu để trống.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-4">
          <!-- Thời gian kết thúc -->
          <div>
            <label for="end_time" class="block text-sm font-semibold text-slate-700 mb-1">
              Thời gian kết thúc
            </label>
            <input id="end_time" name="end_time" type="datetime-local"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent">
            <p class="mt-1 text-xs text-slate-500">Để trống nếu không đặt thời gian kết thúc.</p>
          </div>

          <!-- Tự gia hạn -->
          <div class="flex items-center pt-7">
            <input id="auto_extend" name="auto_extend" type="checkbox" value="true" checked
                   class="h-4 w-4 text-blue-600 border-slate-300 rounded">
            <label for="auto_extend" class="ml-2 text-sm text-slate-700 font-medium">Tự động gia hạn</label>
          </div>
        </div>
      </div>

      <!-- Hình ảnh -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-start border-t pt-6">
        <div>
          <label for="thumbnail" class="block text-sm font-semibold text-slate-700 mb-1">
            Hình ảnh sản phẩm <span class="text-rose-500">*</span>
          </label>
          <input id="thumbnail" name="thumbnail" type="file" accept="image/*" required
                 class="w-full rounded-lg border border-slate-200 px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent">
          <p class="mt-2 text-xs text-slate-500">
            <i class="fas fa-info-circle"></i> Chấp nhận: JPG, PNG, GIF, WEBP. Tối đa 5MB.
          </p>
        </div>
        <div class="flex md:justify-end">
          <img id="preview" class="hidden w-48 h-48 object-cover rounded-xl border border-slate-200 shadow-sm" alt="Preview">
        </div>
      </div>

      <!-- Lưu ý -->
      <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-green-800 text-sm flex gap-2">
        <i class="fas fa-check-circle mt-0.5"></i>
        <div>
          <strong>Lưu ý:</strong> Sản phẩm sẽ được <strong>APPROVED</strong> ngay sau khi đăng.
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex justify-end gap-3">
        <a href="/seller/products" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50">
          Hủy
        </a>
        <button type="submit" id="submitBtn"
                class="px-4 py-2 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
          Đăng sản phẩm
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Đếm ký tự mô tả ngắn
  const shortDesc = document.getElementById('short_description');
  const shortDescCount = document.getElementById('shortDescCount');
  if (shortDesc) {
    shortDesc.addEventListener('input', () => {
      shortDescCount.textContent = shortDesc.value.length;
      shortDescCount.classList.toggle('text-rose-500', shortDesc.value.length >= 500);
    });
  }

  // Preview ảnh
  const thumbInput = document.getElementById('thumbnail');
  const preview = document.getElementById('preview');
  thumbInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) { preview.classList.add('hidden'); return; }
    if (file.size > 5 * 1024 * 1024) {
      alert('Kích thước file không được vượt quá 5MB!');
      thumbInput.value = ''; preview.classList.add('hidden'); return;
    }
    const allowed = ['image/jpeg','image/jpg','image/png','image/gif','image/webp'];
    if (!allowed.includes(file.type)) {
      alert('Chỉ chấp nhận file ảnh (JPG, PNG, GIF, WEBP)!');
      thumbInput.value = ''; preview.classList.add('hidden'); return;
    }
    const reader = new FileReader();
    reader.onload = (ev) => {
      preview.src = ev.target.result;
      preview.classList.remove('hidden');
    };
    reader.readAsDataURL(file);
  });

  // Submit
  document.getElementById('productForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Đang xử lý...';
    const formData = new FormData(this);
    try {
      const res = await fetch('/seller/products', { method: 'POST', body: formData, credentials: 'include' });
      const result = await res.json();
      if (result.success) {
        alert('✅ Sản phẩm đã được đăng (APPROVED).');
        window.location.href = '/seller/products';
      } else {
        alert('❌ Lỗi: ' + result.message);
      }
    } catch (err) {
      console.error(err);
      alert('❌ Có lỗi xảy ra. Vui lòng thử lại!');
    } finally {
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });

  // Cảnh báo rời trang khi có thay đổi
  let formChanged = false;
  document.querySelectorAll('input, textarea, select').forEach(el => {
    el.addEventListener('change', () => { formChanged = true; });
  });
  window.addEventListener('beforeunload', (e) => {
    if (formChanged) { e.preventDefault(); e.returnValue = ''; }
  });
</script>