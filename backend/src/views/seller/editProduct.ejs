<% layout('layouts/main') %>

<div class="max-w-5xl mx-auto px-4 py-10">
  <div class="bg-white shadow rounded-xl border border-slate-100 overflow-hidden">
    <div class="bg-gradient-to-r from-indigo-500 to-violet-500 text-white px-6 py-4">
      <h2 class="text-lg font-semibold">Chỉnh sửa sản phẩm</h2>
    </div>

    <form id="editForm" class="p-6 space-y-6" enctype="multipart/form-data">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-slate-700 mb-1">Tên sản phẩm</label>
          <input name="title" type="text" value="<%= product.title %>"
                 class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:ring-2 focus:ring-indigo-400 focus:border-transparent">
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">Danh mục</label>
          <select name="category_id"
                  class="w-full rounded-lg border border-slate-200 px-3 py-2 bg-white focus:ring-2 focus:ring-indigo-400 focus:border-transparent">
            <% (categories || []).forEach(cat => { %>
              <option value="<%= cat.id %>" <%= cat.id === product.category_id ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">Mô tả ngắn</label>
          <textarea name="short_description" rows="3"
                    class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:ring-2 focus:ring-indigo-400 focus:border-transparent"><%= product.short_description || '' %></textarea>
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 mb-1">Mô tả chi tiết</label>
        <textarea name="full_description" rows="6"
                  class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:ring-2 focus:ring-indigo-400 focus:border-transparent"><%= product.full_description || '' %></textarea>
      </div>

      <!-- Auction info -->
      <div class="border-t pt-6">
        <h3 class="text-md font-semibold text-slate-700 mb-4">Thông tin phiên đấu giá</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <!-- Giá khởi điểm -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Giá khởi điểm (VNĐ)</label>
            <input name="starting_price" type="number" min="0" step="1000"
                   value="<%= auction?.start_price ?? '' %>"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:ring-2 focus:ring-indigo-400 focus:border-transparent">
          </div>
          <!-- Bước giá -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Bước giá (VNĐ)</label>
            <input name="step_price" type="number" min="0" step="1000"
                   value="<%= auction?.step_price ?? '' %>"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:ring-2 focus:ring-indigo-400 focus:border-transparent">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-4">
          <!-- Thời gian kết thúc -->
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Thời gian kết thúc</label>
            <input name="end_time" type="datetime-local"
                   value="<%= auction?.end_time ? new Date(auction.end_time).toISOString().slice(0,16) : '' %>"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:ring-2 focus:ring-indigo-400 focus:border-transparent">
          </div>
          <!-- Tự gia hạn -->
          <div class="flex items-center pt-7">
            <input id="auto_extend" name="auto_extend" type="checkbox" value="true"
                   <%= auction?.auto_extend ? 'checked' : '' %>
                   class="h-4 w-4 text-indigo-600 border-slate-300 rounded">
            <label for="auto_extend" class="ml-2 text-sm text-slate-700 font-medium">Tự động gia hạn</label>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-start border-t pt-6">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">Ảnh hiện tại</label>
          <img src="<%= product.thumbnail || '/images/placeholder.jpg' %>"
               class="w-40 h-40 object-cover rounded-xl border border-slate-200 shadow-sm" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1">Chọn ảnh mới</label>
          <input type="file" name="thumbnail" accept="image/*"
                 class="w-full rounded-lg border border-slate-200 px-3 py-2 bg-white focus:ring-2 focus:ring-indigo-400 focus:border-transparent">
          <p class="mt-2 text-xs text-slate-500">JPG, PNG, GIF, WEBP. Tối đa 5MB.</p>
        </div>
      </div>

      <div class="flex justify-end gap-3">
        <a href="/seller/products" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50">Hủy</a>
        <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700" id="saveBtn">
          Lưu thay đổi
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('editForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('saveBtn');
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Đang lưu...';

    const formData = new FormData(this);
    try {
      const res = await fetch('/seller/products/<%= product.id %>', {
        method: 'PUT',
        body: formData,
        credentials: 'include'
      });
      const result = await res.json();
      if (result.success) {
        alert('✅ Cập nhật thành công');
        window.location.href = '/seller/products';
      } else {
        alert('❌ ' + (result.message || 'Có lỗi xảy ra'));
      }
    } catch (err) {
      console.error(err);
      alert('❌ Có lỗi xảy ra, thử lại sau');
    } finally {
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });
</script>