<% layout('layouts/main') %>

<div class="max-w-5xl mx-auto px-4 py-10">
  <div class="bg-white shadow-xl rounded-2xl border border-slate-100 overflow-hidden">
    <div class="bg-gradient-to-r from-blue-500 to-indigo-500 text-white px-6 py-4 flex items-center gap-2">
      <i class="fas fa-box text-lg"></i>
      <h2 class="text-lg font-semibold">Chỉnh sửa sản phẩm</h2>
    </div>

    <form id="editForm" enctype="multipart/form-data" class="p-6 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <!-- Tên sản phẩm -->
        <div class="md:col-span-2">
          <label for="title" class="block text-sm font-semibold text-slate-700 mb-1">
            Tên sản phẩm <span class="text-rose-500">*</span>
          </label>
          <input id="title" name="title" type="text" required
                 class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                 value="<%= product.title %>">
        </div>

        <!-- Danh mục -->
        <div>
          <label for="category_id" class="block text-sm font-semibold text-slate-700 mb-1">
            Danh mục <span class="text-rose-500">*</span>
          </label>
          <select id="category_id" name="category_id" required
                  class="w-full rounded-lg border border-slate-200 px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent">
            <option value="">-- Chọn danh mục --</option>
            <% (categories || []).forEach(cat => { %>
              <option value="<%= cat.id %>" <%= cat.id === product.category_id ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <!-- Mô tả ngắn -->
        <div>
          <label for="short_description" class="block text-sm font-semibold text-slate-700 mb-1">
            Mô tả ngắn
          </label>
          <textarea id="short_description" name="short_description" rows="3" maxlength="500"
                    class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                    placeholder="Mô tả ngắn gọn (tối đa 500 ký tự)"><%= product.short_description || '' %></textarea>
          <div class="flex items-center justify-between mt-1 text-xs text-slate-500">
            <span>Tối đa 500 ký tự</span>
            <span><span id="shortDescCount"><%= (product.short_description || '').length %></span>/500</span>
          </div>
        </div>
      </div>

      <!-- Mô tả chi tiết -->
      <div>
        <label for="full_description" class="block text-sm font-semibold text-slate-700 mb-1">
          Mô tả chi tiết
        </label>
        <textarea id="full_description" name="full_description" rows="5"
                  class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                  placeholder="Mô tả chi tiết về sản phẩm, tình trạng, nguồn gốc..."><%= product.full_description || '' %></textarea>
      </div>

      <!-- Thông tin phiên đấu giá -->
      <div class="border-t pt-6">
        <h3 class="text-md font-semibold text-slate-700 mb-4">Thông tin phiên đấu giá</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <!-- Giá khởi điểm -->
          <div>
            <label for="starting_price" class="block text-sm font-semibold text-slate-700 mb-1">
              Giá khởi điểm (VNĐ) <span class="text-rose-500">*</span>
            </label>
            <input id="starting_price" name="starting_price" type="number" min="0" step="1000" required
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                   value="<%= auction?.start_price ?? '' %>">
          </div>

          <!-- Bước giá -->
          <div>
            <label for="step_price" class="block text-sm font-semibold text-slate-700 mb-1">
              Bước giá (VNĐ)
            </label>
            <input id="step_price" name="step_price" type="number" min="0" step="1000"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                   value="<%= auction?.step_price ?? 100000 %>">
            <p class="mt-1 text-xs text-slate-500">Mặc định 100.000 VNĐ nếu để trống.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-4">
          <!-- Thời gian kết thúc -->
          <div>
            <label for="end_time" class="block text-sm font-semibold text-slate-700 mb-1">
              Thời gian kết thúc
            </label>
            <input id="end_time" name="end_time" type="datetime-local"
                   class="w-full rounded-lg border border-slate-200 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent"
                   value="<%= auction?.end_time ? new Date(auction.end_time).toISOString().slice(0,16) : '' %>">
            <p class="mt-1 text-xs text-slate-500">Để trống nếu không đặt thời gian kết thúc.</p>
          </div>

          <!-- Tự gia hạn -->
          <div class="flex items-center pt-7">
            <input id="auto_extend" name="auto_extend" type="checkbox" value="true"
                   <%= auction?.auto_extend ? 'checked' : '' %>
                   class="h-4 w-4 text-blue-600 border-slate-300 rounded">
            <label for="auto_extend" class="ml-2 text-sm text-slate-700 font-medium">Tự động gia hạn</label>
          </div>
        </div>
      </div>

      <!-- Cho phép user uy tín thấp -->
      <div class="border-t pt-6">
        <div class="flex items-start justify-between gap-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <div>
            <div class="text-sm font-semibold text-slate-700">Allow negative user</div>
            <div class="text-xs text-slate-500 mt-0.5">
              Nếu bật, người dùng có <b>điểm uy tín &lt; 5</b> vẫn được phép bid / auto-bid / mua ngay.
            </div>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input id="allow_negative_user" name="allow_negative_user" type="checkbox" value="true" class="sr-only peer"
              <%= product.allow_negative_user ? 'checked' : '' %>>
            <div class="w-11 h-6 bg-slate-300 rounded-full peer peer-checked:bg-blue-600 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
          </label>
        </div>
      </div>

      <!-- Hình ảnh (bắt buộc 4 ảnh) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-start border-t pt-6">
        <div>
          <label for="images" class="block text-sm font-semibold text-slate-700 mb-1">
            Hình ảnh sản phẩm (bắt buộc 4 ảnh)
          </label>
          <div class="flex gap-2 mb-2">
            <% 
              let productImages = [];
              try {
                productImages = product.images ? JSON.parse(product.images) : [];
              } catch(e) {
                // Fallback to old local paths
                for(let i=0; i<4; i++) {
                  productImages.push(`/uploads/products/${product.id}/${i}.jpg`);
                }
              }
              
              for(let i=0; i<4; i++) { 
                const imgSrc = productImages[i] || '/images/placeholder.jpg';
            %>
              <img src="<%= imgSrc %>"
                   class="w-24 h-24 object-cover rounded border border-slate-200 shadow-sm"
                   onerror="this.src='/images/placeholder.jpg'">
            <% } %>
          </div>
          <input id="images" name="images" type="file" accept="image/*" multiple
                 class="w-full rounded-lg border border-slate-200 px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent">
          <p class="mt-2 text-xs text-slate-500">
            <i class="fas fa-info-circle"></i> Chọn đúng 4 ảnh nếu muốn thay đổi (bắt buộc 4 ảnh, thay toàn bộ).
          </p>
          <p id="imagesHint" class="mt-1 text-xs text-rose-600 hidden">Bạn phải chọn đúng 4 ảnh.</p>
        </div>
        <div>
          <div class="grid grid-cols-2 gap-3">
            <img id="preview0" class="hidden w-full h-32 object-cover rounded-xl border border-slate-200 shadow-sm" alt="Preview 1">
            <img id="preview1" class="hidden w-full h-32 object-cover rounded-xl border border-slate-200 shadow-sm" alt="Preview 2">
            <img id="preview2" class="hidden w-full h-32 object-cover rounded-xl border border-slate-200 shadow-sm" alt="Preview 3">
            <img id="preview3" class="hidden w-full h-32 object-cover rounded-xl border border-slate-200 shadow-sm" alt="Preview 4">
          </div>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex justify-end gap-3">
        <a href="/seller/products" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50">
          Hủy
        </a>
        <button type="submit" id="saveBtn"
                class="px-4 py-2 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
          Lưu thay đổi
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Đếm ký tự mô tả ngắn
  const shortDesc = document.getElementById('short_description');
  const shortDescCount = document.getElementById('shortDescCount');
  if (shortDesc) {
    shortDesc.addEventListener('input', () => {
      shortDescCount.textContent = shortDesc.value.length;
      shortDescCount.classList.toggle('text-rose-500', shortDesc.value.length >= 500);
    });
  }

  // Preview ảnh (bắt buộc 4 ảnh)
  const imagesInput = document.getElementById('images');
  const imagesHint = document.getElementById('imagesHint');
  const previews = [
    document.getElementById('preview0'),
    document.getElementById('preview1'),
    document.getElementById('preview2'),
    document.getElementById('preview3'),
  ];

  const resetPreviews = () => {
    previews.forEach((img) => { img.src = ''; img.classList.add('hidden'); });
  };

  imagesInput.addEventListener('change', () => {
    const files = Array.from(imagesInput.files || []);
    resetPreviews();

    // Require exactly 4 files if user chooses to upload
    if (files.length !== 0 && files.length !== 4) {
      imagesHint.classList.remove('hidden');
      return;
    }
    imagesHint.classList.add('hidden');

    const allowed = ['image/jpeg','image/jpg','image/png','image/gif','image/webp'];
    for (const f of files) {
      if (f.size > 5 * 1024 * 1024) {
        alert('Kích thước mỗi ảnh không được vượt quá 5MB!');
        imagesInput.value = '';
        resetPreviews();
        imagesHint.classList.remove('hidden');
        return;
      }
      if (!allowed.includes(f.type)) {
        alert('Chỉ chấp nhận file ảnh (JPG, PNG, GIF, WEBP)!');
        imagesInput.value = '';
        resetPreviews();
        imagesHint.classList.remove('hidden');
        return;
      }
    }

    // Render previews in chosen order
    files.forEach((f, idx) => {
      if (idx > 3) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        previews[idx].src = ev.target.result;
        previews[idx].classList.remove('hidden');
      };
      reader.readAsDataURL(f);
    });
  });

  // Submit
  document.getElementById('editForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    // Nếu user upload ảnh mới thì phải đủ 4 ảnh, nếu không thì giữ nguyên ảnh cũ
    const files = Array.from(document.getElementById('images').files || []);
    if (files.length !== 0 && files.length !== 4) {
      alert('❌ Vui lòng chọn đúng 4 ảnh sản phẩm nếu muốn thay đổi ảnh.');
      return;
    }

    const btn = document.getElementById('saveBtn');
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Đang lưu...';
    const formData = new FormData(this);
    try {
      const res = await fetch('/seller/products/<%= product.id %>', {
        method: 'PUT',
        body: formData,
        credentials: 'include',
        headers: { 'Accept': 'application/json' }
      });
      const result = await res.json();
      if (result.success) {
        alert('✅ Cập nhật thành công');
        window.location.href = '/seller/products';
      } else {
        alert('❌ ' + (result.message || 'Có lỗi xảy ra'));
      }
    } catch (err) {
      console.error(err);
      alert('❌ Có lỗi xảy ra, thử lại sau');
    } finally {
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });

  // Cảnh báo rời trang khi có thay đổi
  let formChanged = false;
  document.querySelectorAll('input, textarea, select').forEach(el => {
    el.addEventListener('change', () => { formChanged = true; });
  });
  window.addEventListener('beforeunload', (e) => {
    if (formChanged) { e.preventDefault(); e.returnValue = ''; }
  });
</script>