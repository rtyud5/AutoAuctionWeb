<% layout('layouts/main') %>

<div class="max-w-5xl mx-auto px-6 py-8">
  <h1 class="text-2xl font-bold mb-6">Câu hỏi của người mua</h1>

  <% if (questions && questions.length) { %>
    <div class="space-y-4">
      <% questions.forEach(q => { %>
        <div class="border border-gray-200 bg-white rounded-xl shadow-sm hover:shadow-md transition p-5">
          <div class="flex justify-between items-start mb-2">
            <div>
              <p class="font-semibold text-gray-900"><%= q.user_name || 'Ẩn danh' %></p>
              <p class="text-xs text-gray-500"><%= new Date(q.created_at).toLocaleString('vi-VN') %></p>
              <p class="text-sm text-gray-600 mt-1">
                Sản phẩm:
                <strong>
                  <a href="/product/<%= q.product_id %>" class="text-blue-600 hover:underline">
                    <%= q.product_title %>
                  </a>
                </strong>
              </p>
            </div>
            <% if (q.answer) { %>
              <span class="inline-flex items-center px-3 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-700">Đã trả lời</span>
            <% } else { %>
              <span class="inline-flex items-center px-3 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-700">Chờ trả lời</span>
            <% } %>
          </div>

          <p class="text-gray-800 mb-3"><span class="font-semibold">Hỏi:</span> <%= q.question %></p>

          <% if (q.answer) { %>
            <div class="mt-3 pl-4 border-l-4 border-green-400 bg-green-50 rounded-lg py-3">
              <p class="text-sm font-semibold text-green-800 mb-1">Trả lời</p>
              <p class="text-gray-700 text-sm"><%= q.answer %></p>
              <p class="text-xs text-gray-500 mt-2"><%= new Date(q.answered_at).toLocaleString('vi-VN') %></p>
            </div>
          <% } else { %>
            <form onsubmit="answerQuestion(event, <%= q.id %>)" class="space-y-3 mt-2">
              <textarea
                id="answer-<%= q.id %>"
                class="w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:border-blue-500"
                rows="3"
                placeholder="Nhập câu trả lời..."
                required></textarea>
              <div class="flex justify-end">
                <button type="submit" class="bg-blue-600 text-white rounded-lg px-5 py-2 hover:bg-blue-700 transition">Gửi trả lời</button>
              </div>
            </form>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="p-10 text-center text-gray-500 bg-gray-50 rounded-xl border border-dashed border-gray-200">
      Chưa có câu hỏi nào
    </div>
  <% } %>

  <% if (pagination && pagination.total > 0) { %>
    <div class="flex items-center justify-between mt-6 text-sm">
      <% const prev = Math.max(1, pagination.page - 1); %>
      <% const next = Math.min(pagination.totalPages, pagination.page + 1); %>

      <a class="px-3 py-2 border rounded <%= pagination.page === 1 ? 'pointer-events-none opacity-50' : '' %>"
         href="?page=<%= prev %>&limit=<%= pagination.limit %>">« Trước</a>

      <span>Trang <%= pagination.page %> / <%= pagination.totalPages %> · <%= pagination.total %> câu hỏi</span>

      <a class="px-3 py-2 border rounded <%= pagination.page === pagination.totalPages ? 'pointer-events-none opacity-50' : '' %>"
         href="?page=<%= next %>&limit=<%= pagination.limit %>">Sau »</a>
    </div>
  <% } %>
</div>

<script>
  function answerQuestion(e, id) {
    e.preventDefault();
    const val = document.getElementById(`answer-${id}`).value.trim();
    if (!val) return alert('Vui lòng nhập câu trả lời');
    fetch(`/api/questions/${id}/answer`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ answer: val })
    })
    .then(r => r.json().catch(() => ({})).then(d => ({ ok: r.ok, d })))
    .then(({ ok, d }) => {
      if (!ok || !d.success) return alert(d.message || 'Trả lời thất bại');
      alert('Đã gửi trả lời');
      window.location.reload();
    })
    .catch(() => alert('Trả lời thất bại'));
  }
</script>