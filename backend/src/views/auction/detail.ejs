<% layout("layouts/main") %>

<section class="py-8">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left: Image & basic info -->
    <div class="lg:col-span-2 space-y-4">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="aspect-video bg-slate-100 flex items-center justify-center text-slate-400 text-sm">
          <!-- Placeholder image; có thể thay bằng ảnh thật -->
          <span>Hình sản phẩm đang được cập nhật</span>
        </div>
        <div class="px-5 py-4 border-t border-slate-100">
          <h1 class="text-2xl font-semibold text-slate-800 mb-2"><%= auction.title %></h1>
          <p class="text-sm text-slate-600 mb-1">
            Mã phiên: <span class="font-mono text-slate-800">#<%= auction.id %></span>
          </p>
          <p class="text-sm text-slate-600">
            Kết thúc: <span class="font-medium"><%= auction.end_time || "Đang cập nhật" %></span>
          </p>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 px-5 py-4">
        <h2 class="text-lg font-semibold text-slate-800 mb-2">Mô tả sản phẩm</h2>
        <p class="text-sm text-slate-600 leading-relaxed">
          <%= auction.description || "Chưa có mô tả" %>
        </p>
      </div>
    </div>

    <!-- Right: Bidding panel -->
    <div class="space-y-6">
      <!-- Current price & manual bid -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 px-5 py-5">
        <h2 class="text-lg font-semibold text-slate-800 mb-3">Đặt giá thủ công</h2>

        <p class="text-sm text-slate-600 mb-3">
          Giá hiện tại:
          <span class="text-xl font-semibold text-teal-600">
            <%= auction.current_price %> VNĐ
          </span>
        </p>

        <form method="post" action="/bidder/auctions/<%= auction.id %>/bid" class="space-y-3">
          <div>
            <label for="amount" class="block text-sm font-medium text-slate-700 mb-1">
              Giá bid của bạn
            </label>
            <input
              type="number"
              id="amount"
              name="amount"
              required
              class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-teal-400 focus:ring-2 focus:ring-teal-100 focus:outline-none"
              min="<%= auction.current_price %>"
            />
          </div>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-full bg-teal-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-teal-700 focus:ring-2 focus:ring-offset-1 focus:ring-teal-600/70"
          >
            Đặt giá
          </button>
        </form>
      </div>

      <!-- Auto bid configuration -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 px-5 py-5">
        <h2 class="text-lg font-semibold text-slate-800 mb-2">Tự động đấu giá</h2>
        <p class="text-sm text-slate-600 mb-4">
          Đặt mức giá tối đa bạn sẵn sàng trả, hệ thống sẽ tự động tăng giá theo từng bước khi có người khác ra giá.
        </p>

        <form method="post" action="/bidder/auctions/<%= auction.id %>/auto-bid" class="space-y-3">
          <div>
            <label for="max_amount" class="block text-sm font-medium text-slate-700 mb-1">
              Giá tối đa (auto-bid)
            </label>
            <input
              type="number"
              id="max_amount"
              name="max_amount"
              min="<%= auction.current_price %>"
              required
              class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-teal-400 focus:ring-2 focus:ring-teal-100 focus:outline-none"
            />
          </div>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800 focus:ring-2 focus:ring-offset-1 focus:ring-slate-900/60"
          >
            Lưu cấu hình auto-bid
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
