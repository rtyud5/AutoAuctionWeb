<% layout("layouts/main") %>

<section class="py-8">
  <div class="max-w-5xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-4 text-xs text-slate-500">
      <a href="/" class="hover:text-teal-600">Trang chủ</a>
      <span class="mx-1">/</span>
      <a href="/electronics" class="hover:text-teal-600">Đấu giá</a>
      <span class="mx-1">/</span>
      <span class="text-slate-700 font-medium"><%= auction.title %></span>
    </nav>

    <div class="grid gap-8 md:grid-cols-5">
      <!-- Left: image + description -->
      <div class="md:col-span-3 space-y-4">
        <!-- Product image placeholder -->
        <div class="aspect-video rounded-2xl bg-slate-100 border border-slate-200 flex items-center justify-center text-slate-400 text-sm">
          Hình ảnh sản phẩm (banner)
        </div>

        <div class="space-y-2">
          <h1 class="text-2xl font-semibold text-slate-900">
            <%= auction.title %>
          </h1>

          <p class="text-sm text-slate-500">
            <%= auction.description || "Chưa có mô tả cho phiên đấu giá này." %>
          </p>
        </div>
      </div>

      <!-- Right: bidding panels -->
      <div class="md:col-span-2 space-y-5">
        <!-- Current price -->
        <div class="rounded-2xl border border-teal-100 bg-teal-50 p-4 space-y-1">
          <p class="text-xs font-medium text-teal-700 uppercase tracking-wide">Giá hiện tại</p>
          <p class="text-2xl font-semibold text-teal-900">
            <%= auction.current_price %> VNĐ
          </p>
        </div>

        <!-- Buy now -->
        <div class="rounded-2xl border border-red-100 bg-red-50 p-4 space-y-3 shadow-sm">
          <h2 class="text-sm font-semibold text-red-900 uppercase tracking-wide">
            Mua ngay
          </h2>
          <p class="text-xs text-red-700">
            Mua ngay với giá <b><%= Math.floor(Number(auction.current_price || 0) * 1.5).toLocaleString('vi-VN') %> VNĐ</b>. Phiên đấu giá sẽ kết thúc.
          </p>
          <form method="post" action="/auctions/<%= auction.id %>/buy" onsubmit="return confirm('Bạn chắc chắn muốn MUA NGAY? Phiên đấu giá sẽ kết thúc.');">
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
            >
              Mua ngay
            </button>
          </form>
        </div>

        <!-- Auto-bid -->
        <div class="rounded-2xl border border-slate-200 bg-white p-4 space-y-3 shadow-sm">
          <h2 class="text-sm font-semibold text-slate-900 uppercase tracking-wide">
            Tự động đấu giá
          </h2>
          <p class="text-xs text-slate-500">
            Đặt mức giá tối đa bạn sẵn sàng trả. Hệ thống sẽ tự động tăng theo từng bước khi có người khác ra giá.
          </p>

          <form method="post" action="/auctions/<%= auction.id %>/auto-bid" class="space-y-3">
            <div class="space-y-1">
              <label for="autoBidMax" class="text-xs font-medium text-slate-600">Giá tối đa (VNĐ)</label>
              <input
                id="autoBidMax"
                type="number"
                name="max_amount"
                min="<%= auction.current_price %>"
                max="<%= Math.max(0, Math.floor(Number(auction.current_price || 0) * 1.5) - 1) %>"
                required
                class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500"
              />
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-900"
            >
              Lưu cấu hình auto-bid
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
