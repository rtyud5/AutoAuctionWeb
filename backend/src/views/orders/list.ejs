<% layout('layouts/main') %>

<section class="container mx-auto py-10">
  <h1 class="text-2xl font-semibold mb-6">Đơn hàng</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Buy orders -->
    <div class="bg-white rounded shadow p-4">
      <h2 class="font-medium mb-3">Đơn mua (Đơn tôi mua)</h2>
      <% if (!buyOrders || buyOrders.length === 0) { %>
        <p class="text-sm text-slate-500">Bạn chưa có đơn mua nào.</p>
      <% } else { %>
        <ul class="space-y-3">
          <% buyOrders.forEach(function(o) { %>
            <li class="border rounded p-3">
              <div class="flex items-start justify-between">
                <div>
                  <a href="/orders/<%= o.id %>/view" class="font-semibold text-teal-600 hover:underline">Đơn #<%= o.id %></a>
                  <div class="text-sm text-slate-600"><%= o.product_title || 'Sản phẩm đã xóa' %></div>
                  <div class="text-xs text-slate-500">Ngày: <%= new Date(o.created_at).toLocaleString() %></div>
                </div>
                <div class="text-right">
                  <div class="text-sm"><%= o.status %></div>
                  <div class="text-sm font-semibold">Giá: <%= o.final_price ? (new Intl.NumberFormat('vi-VN').format(o.final_price)) + '₫' : '-' %></div>
                </div>
              </div>
              <div class="mt-3 text-sm bg-slate-50 p-2 rounded">
                <div><strong>Người mua:</strong> <%= o.buyerInfo && (o.buyerInfo.name || o.buyerInfo.fullname) ? (o.buyerInfo.name || o.buyerInfo.fullname) : (o.buyer_name_resolved || o.buyer_name || o.buyer_id) %></div>
                <div><strong>SĐT:</strong> <%= o.buyerInfo && o.buyerInfo.phone ? o.buyerInfo.phone : (o.buyerInfo && o.buyerInfo.phone_number ? o.buyerInfo.phone_number : '—') %></div>
                <div><strong>Địa chỉ:</strong> <%= o.buyerInfo && o.buyerInfo.address ? o.buyerInfo.address : (o.buyerInfo && o.buyerInfo.address_line ? o.buyerInfo.address_line : '—') %></div>
                <% if (o.note) { %>
                  <div class="mt-1"><strong>Ghi chú:</strong> <%= o.note %></div>
                <% } %>
                <div class="mt-1 text-xs text-green-700">Đơn hàng sẽ được giao trong vòng 7 ngày (trước <%= new Date(o.estimated_delivery).toLocaleDateString() %>).</div>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>

    <!-- Sell orders -->
    <div class="bg-white rounded shadow p-4">
      <h2 class="font-medium mb-3">Đơn bán (Đơn tôi bán)</h2>
      <% if (!sellOrders || sellOrders.length === 0) { %>
        <p class="text-sm text-slate-500">Bạn chưa có đơn bán nào.</p>
      <% } else { %>
        <ul class="space-y-3">
          <% sellOrders.forEach(function(o) { %>
            <li class="border rounded p-3 flex items-start justify-between">
              <div>
                <a href="/orders/<%= o.id %>/view" class="font-semibold text-teal-600 hover:underline">Đơn #<%= o.id %></a>
                <div class="text-sm text-slate-600"><%= o.product_title || 'Sản phẩm đã xóa' %></div>
                <div class="text-xs text-slate-500">Ngày: <%= new Date(o.created_at).toLocaleString() %></div>
              </div>
              <div class="text-right">
                <div class="text-sm"><%= o.status %></div>
                <div class="text-sm font-semibold">Giá: <%= o.final_price ? (new Intl.NumberFormat('vi-VN').format(o.final_price)) + '₫' : '-' %></div>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </div>
</section>
