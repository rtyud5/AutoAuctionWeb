<style>
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {

  /* ================= SELLER COUNTDOWN (DASHBOARD) ================= */
  (async function initSellerCountdown() {
    try {
      const resp = await fetch('/me', { credentials: 'same-origin' });
      if (!resp.ok) {
        console.warn('GET /me failed', resp.status);
        return;
      }

      const data = await resp.json().catch(() => ({}));
      console.log('ME API:', data);

      const user = data?.user;
      if (!user) return;

      const role = (user.role || '').toLowerCase();
      if (role !== 'seller') return;

      const exp = user.seller_expires_at;
      if (!exp) {
        console.warn('Seller has no seller_expires_at');
        return;
      }

      const expiresAt = new Date(exp);
      if (isNaN(expiresAt.getTime())) {
        console.error('Invalid expires date:', exp);
        return;
      }

      const badge = document.getElementById('seller-badge');
      const countdownEl = document.getElementById('seller-countdown');

      if (!badge || !countdownEl) {
        console.error('Missing #seller-badge or #seller-countdown in HTML');
        return;
      }

      badge.classList.remove('hidden');

      const update = () => {
        const diff = expiresAt - new Date();

        if (diff <= 0) {
          countdownEl.textContent = 'Hết hạn Seller';
          clearInterval(timer);
          // Có thể reload để backend cập nhật role
          // location.reload();
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        countdownEl.textContent =
          `${days} ngày ${String(hours).padStart(2,'0')}:${String(minutes).padStart(2,'0')}:${String(seconds).padStart(2,'0')}`;
      };

      update();
      const timer = setInterval(update, 1000);

    } catch (e) {
      console.error('seller countdown init failed', e);
    }
  })();


  /* ================= EXISTING CAROUSEL CODE (GIỮ NGUYÊN) ================= */
  document.querySelectorAll('.auction-section').forEach(section => {
    const viewport = section.querySelector('.carousel-viewport');
    const track = section.querySelector('.carousel-track');
    const cards = Array.from(section.querySelectorAll('.auction-card'));
    const prevBtn = section.querySelector('.carousel-prev');
    const nextBtn = section.querySelector('.carousel-next');
    const dotsWrap = section.querySelector('.carousel-dots');
    if (!viewport || !track || cards.length === 0) return;

    const getPerPage = () => {
      const w = window.innerWidth;
      if (w >= 1024) return 3;
      if (w >= 640) return 2;
      return 1;
    };

    const setCardWidths = (perPage) => {
      const style = getComputedStyle(track);
      const gap = parseFloat(style.gap) || 24;
      const avail = Math.max(0, viewport.clientWidth - gap * (perPage - 1));
      const cw = Math.floor(avail / perPage);
      cards.forEach(card => card.style.width = cw + 'px');
    };

    let perPage = getPerPage();
    setCardWidths(perPage);

    let pages = Math.max(1, Math.ceil(cards.length / perPage));
    let currentPage = 0;

    const buildDots = () => {
      dotsWrap.innerHTML = '';
      for (let i = 0; i < pages; i++) {
        const d = document.createElement('button');
        d.className = 'w-3 h-3 rounded-full bg-gray-300';
        d.addEventListener('click', () => goToPage(i));
        dotsWrap.appendChild(d);
      }
      updateDots();
    };

    const updateDots = () => {
      Array.from(dotsWrap.children).forEach((dot, idx) => {
        dot.classList.toggle('bg-teal-500', idx === currentPage);
        dot.classList.toggle('bg-gray-300', idx !== currentPage);
      });
    };

    const goToPage = (page) => {
      perPage = getPerPage();
      pages = Math.max(1, Math.ceil(cards.length / perPage));
      currentPage = Math.max(0, Math.min(page, pages - 1));
      const targetIndex = currentPage * perPage;
      const targetCard = cards[targetIndex];
      if (targetCard) {
        viewport.scrollTo({ left: targetCard.offsetLeft - track.offsetLeft, behavior: 'smooth' });
      }
      updateDots();
    };

    if (prevBtn) prevBtn.addEventListener('click', () => goToPage(currentPage - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => goToPage(currentPage + 1));

    buildDots();
    goToPage(0);
  });

  /* ================= RELATED CARDS COUNTDOWN ================= */
  (function startCardCountdowns() {
    const els = Array.from(document.querySelectorAll('.countdown-text'));
    const remainEls = Array.from(document.querySelectorAll('.time-remaining'));

    function formatRemaining(diff) {
      if (diff <= 0) return 'Đã kết thúc';
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);
      if (days > 0) return `${days}d ${String(hours).padStart(2,'0')}:${String(minutes).padStart(2,'0')}:${String(seconds).padStart(2,'0')}`;
      return `${String(hours).padStart(2,'0')}:${String(minutes).padStart(2,'0')}:${String(seconds).padStart(2,'0')}`;
    }

    function tick() {
      const now = Date.now();
      // update countdown-text elements (they show end timestamp already; keep them static)
      // update remaining time elements
      remainEls.forEach(el => {
        const endMs = Number(el.getAttribute('data-end-ms')) || null;
        const target = el.querySelector('.time-remaining-text');
        if (!target) return;
        if (!endMs) {
          target.textContent = '—';
          return;
        }
        const diff = endMs - now;
        target.textContent = formatRemaining(diff);
      });
    }

    tick();
    setInterval(tick, 1000);
  })();
});
</script>


