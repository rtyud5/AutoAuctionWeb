<!-- Section Template -->
<% 
const sections = [
    { title: 'Sản phẩm mới nhất', data: auctions.endingSoon || [] },
    { title: 'Sản phẩm nổi bật', data: auctions.highestPrice || [] },
    { title: 'Sản phẩm đề xuất', data: auctions.mostBids || [] }
];
%>

<% sections.forEach((section, sidx) => { %>
    <section class="auction-section mb-12">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-semibold text-gray-800">
                <%= section.title %>
            </h2>
        </div>

        <% if (section.data.length === 0) { %>
            <div class="bg-gray-100 rounded-xl p-8 text-center text-gray-500">
                Chưa có sản phẩm nào
            </div>
        <% } else { %>
            <!-- CAROUSEL: shows 3 cards per view; arrows + dots if more -->
            <div class="relative">
                <!-- viewport -->
                <div class="carousel-viewport overflow-hidden">
                    <!-- track: flex list of cards -->
                    <div class="carousel-track flex gap-6 snap-x snap-mandatory">
                        <% section.data.forEach((product, idx) => { %>
                            <div class="auction-card flex-shrink-0 w-full sm:w-1/2 md:w-1/3 snap-start">
                                <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition p-4 flex gap-4 h-full">
                                    <!-- Image -->
                                    <div class="auction-img w-32 h-32 bg-gray-200 rounded-lg overflow-hidden">
                                        <% const imgSrc = product.image || `/uploads/products/${product.product_id}/0.jpg`; %>
                                        <% if (imgSrc) { %>
                                            <img src="<%= imgSrc %>" 
                                                alt="<%= product.title %>"
                                                class="w-full h-full object-cover">
                                        <% } else { %>
                                            <span class="text-gray-500 text-sm flex items-center justify-center h-full">No Image</span>
                                        <% } %>
                                    </div>
                                    
                                    <!-- Info -->
                                    <div class="auction-info flex flex-col justify-between w-full">
                                        <div>
                                            <h3 class="text-lg font-bold text-gray-700 mb-1 line-clamp-2">
                                                <%= product.title %>
                                            </h3>
                                            <% if (product.short_description) { %>
                                                <p class="text-sm text-gray-600 mb-2 line-clamp-2">
                                                    <%= product.short_description %>
                                                </p>
                                            <% } %>
                                            
                      <!-- Giá và số lượt đấu -->
                      <% if (product.current_price || product.start_price) { %>
                        <div class="mb-2 space-y-1">
                          <p class="text-sm font-semibold text-green-600">
                            <i class="fas fa-dollar-sign"></i>
                            Giá hiện tại: <%= Number(product.current_price || product.start_price || 0).toLocaleString('vi-VN') %> VNĐ
                          </p>
                          <% if (product.bid_count > 0) { %>
                            <p class="text-xs text-gray-500">
                              <i class="fas fa-gavel"></i> <%= product.bid_count %> lượt đấu giá
                            </p>
                          <% } %>
                          <p class="text-xs text-gray-500" data-end-ms="<%= product.end_time_ms || '' %>">
                            ⏰ Kết thúc: <span class="countdown-text"><%= product.end_time ? new Date(product.end_time).toLocaleString('vi-VN') : '—' %></span>
                          </p>
                        </div>
                      <% } %>                   
                                            <p class="text-sm text-gray-500">
                                                <i class="fas fa-tag"></i> <%= product.category_name || 'N/A' %>
                                            </p>
                                            <p class="text-sm text-gray-500">
                                                <i class="fas fa-user"></i> <%= product.seller_name || 'Seller' %>
                                            </p>
                                        </div>
                                        <button
                                        onclick="window.location.href='/product/<%= product.product_id || product.id %>'"
                                        class="btn-auction mt-3 bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg transition w-full text-sm">
                                        <i class="fas fa-eye"></i> Xem chi tiết
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- arrows -->
                <% if (section.data.length > 3) { %>
                    <button aria-label="prev"
                        class="carousel-prev absolute left-0 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white p-2 rounded-full shadow hidden md:flex">
                        <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                    </button>
                    <button aria-label="next"
                        class="carousel-next absolute right-0 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white p-2 rounded-full shadow hidden md:flex">
                        <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                <% } %>

                <!-- dots -->
                <div class="carousel-dots mt-4 flex justify-center gap-2"></div>
            </div>
        <% } %>
    </section>
<% }) %>

