<!-- Banner -->
<section class="flex flex-col md:flex-row items-center justify-between bg-gradient-to-r from-blue-500 to-blue-700 text-white px-8 py-16 rounded-2xl shadow-lg mb-12">
    <div class="banner-left max-w-lg">
        <h1 class="text-4xl font-bold mb-4">ĐẤU GIÁ TRỰC TUYẾN</h1>
        <p class="text-lg opacity-90 mb-2">Mô tả ngắn về hệ thống đấu giá trực tuyến...</p>
        <p class="opacity-90">📞 1234567894</p>
        <p class="opacity-90">🌐 https://daugia.asian/dau-gia</p>
    </div>

    <div class="banner-right mt-8 md:mt-0">
        <div class="banner-img w-72 h-48 bg-white/20 rounded-xl flex items-center justify-center text-white text-lg">
            Hình Banner
        </div>
    </div>
</section>

<!-- Section Template -->
<% const sections = [

'Top 5 sản phẩm giá rẻ nhất',
    'Top 5 sản phẩm có nhiều lượt ra giá nhất',
    'Top 5 sản phẩm giá cao nhất'
]; %>

<% sections.forEach(title => { %>
<section class="auction-section mb-12">
    <h2 class="text-2xl font-semibold mb-6 text-gray-800"><%= title %></h2>

    <div class="auction-list grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% for (let i = 0; i < 5; i++) { %>
        <div class="auction-card bg-white rounded-xl shadow-md hover:shadow-xl transition p-4 flex gap-4">
            
            <!-- Image -->
            <div class="auction-img w-32 h-32 bg-gray-200 rounded-lg flex items-center justify-center text-gray-500">
                Hình
            </div>

            <!-- Info -->
            <div class="auction-info flex flex-col justify-between w-full">
                <div>
                    <h3 class="text-lg font-bold text-gray-700 mb-1">Tên sản phẩm: ___ </h3>
                    <% if (title.includes('nhiều lượt')) { %>
                        <p>Số lượt ra giá: ________</p>
                        <p>Giá hiện tại: ________</p>
                        <p>Ngày đăng: ________</p>
                        <p>Bidder cao nhất: _____</p>
                        <p>Thời gian còn lại: ___</p>
                        <p>Giá mua ngay: __ </p>
                    <% } else if (title.includes('giá cao nhất')) { %>
                        <p>Số lượt ra giá: ________</p>
                        <p>Giá hiện tại: ________</p>
                        <p>Ngày đăng: ________</p>
                        <p>Bidder cao nhất: _____</p>
                        <p>Thời gian còn lại: ___</p>
                        <p>Giá mua ngay: __ </p>
                    <% } else { %>
                        <p>Số lượt ra giá: ________</p>
                        <p>Giá hiện tại: ________</p>
                        <p>Ngày đăng: ________</p>
                        <p>Bidder cao nhất: _____</p>
                        <p>Thời gian còn lại: ___</p>
                        <p>Giá mua ngay: __ </p>
                    <% } %>
                </div>

                <button class="btn-auction mt-3 bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg transition">
                    View Product
                </button>
            </div>
        </div>
        <% } %>
    </div>
</section>
<% }) %>

