<% layout("layouts/main") %>

<main>
  <section class="mb-6">
    <h1 class="text-3xl font-semibold mb-1">Online Auction System</h1>
    <p class="text-gray-600">Danh sách phiên đấu giá sắp kết thúc:</p>
  </section>

  <section class="grid gap-6 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
    <% if (auctions && auctions.length) { %>
      <% auctions.forEach(a => { %>
        <article class="bg-white rounded-lg shadow hover:shadow-md transition p-0 flex flex-col overflow-hidden">
          <a href="/auctions/<%= a.id %>" class="block h-44 bg-gray-100">
            <img src="<%= a.image || '/images/placeholder.svg' %>" alt="<%= a.title || a.name || 'No title' %>" class="w-full h-full object-cover" />
          </a>

          <div class="p-4 flex-1 flex flex-col">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium">
                <a href="/auctions/<%= a.id %>" class="hover:text-teal-600"><%= a.title || a.name || 'Untitled' %></a>
              </h3>
              <% if (a.is_new) { %>
                <span class="ml-2 inline-block bg-pink-500 text-white text-xs px-2 py-1 rounded">New</span>
              <% } %>
            </div>

            <p class="text-sm text-gray-800 font-semibold mt-2">Giá hiện tại: <span class="text-teal-600"><%= a.current_price ? a.current_price.toLocaleString() : '0' %> VNĐ</span></p>
            <p class="text-xs text-gray-500 mt-1">Bên đấu giá: <%= a.top_bidder ? (a.top_bidder.maskedName || a.top_bidder.name) : '---' %></p>
            <p class="text-xs text-gray-500">Kết thúc: <%= a.end_time %></p>

            <div class="mt-4 flex items-center gap-2">
              <a href="/auctions/<%= a.id %>" class="px-3 py-1 border rounded text-sm text-gray-700 hover:bg-gray-50">Xem chi tiết</a>
              <form action="/auctions/<%= a.id %>/buy" method="post" class="ml-auto">
                <button class="px-3 py-1 bg-teal-500 text-white rounded text-sm hover:bg-teal-600" type="submit">Mua ngay</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <div class="col-span-full bg-white rounded-lg p-6 text-center text-gray-600 shadow">
        Chưa có phiên đấu giá demo. Thêm dữ liệu trong MySQL để hiển thị.
      </div>
    <% } %>
  </section>

  <nav class="mt-8 flex justify-center items-center gap-2">
    <% if (typeof pagination !== 'undefined' && pagination) { %>
      <% if (pagination.prev) { %>
        <a href="<%= pagination.prev %>" class="w-10 h-10 flex items-center justify-center rounded-full border text-gray-600">‹</a>
      <% } %>
      <% (pagination.pages || []).forEach(p => { %>
        <a href="<%= p.url %>" class="w-10 h-10 flex items-center justify-center rounded-full border <%= p.current ? 'bg-teal-500 text-white' : 'text-gray-600' %>"><%= p.num %></a>
      <% }) %>
      <% if (pagination.next) { %>
        <a href="<%= pagination.next %>" class="w-10 h-10 flex items-center justify-center rounded-full border text-gray-600">›</a>
      <% } %>
    <% } %>
  </nav>
</main>