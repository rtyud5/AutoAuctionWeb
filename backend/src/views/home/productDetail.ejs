<% layout('layouts/main') %>

    <div class="relative bg-gradient-to-br from-blue-100 via-purple-50 to-pink-50 p-6 overflow-hidden">

            <!-- Background decorations (LUON o SAU) -->
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute top-8 right-1/4 w-32 h-32 bg-gradient-to-br from-blue-200 to-transparent rounded-full opacity-50"></div>
                <div class="absolute top-4 right-1/3 w-24 h-24 bg-gradient-to-br from-purple-200 to-transparent rounded-full opacity-40"></div>
            </div>

            <!-- Title -->
            <h1 class="text-2xl font-bold text-gray-800 text">
                <%= product.title %>
            </h1>
        </div>

         <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 mt-6 relative z-40">
            <!-- Left Column - Product Images -->
            <div>
                <% const images = (product.images && product.images.length) ? product.images : [product.image].filter(Boolean); %>
                <div class="bg-white rounded-lg p-4 shadow-md mb-4">
                <img src="<%= images[0] %>" alt="<%= product.title %>" class="w-full rounded-lg" id="mainImage">
                </div>

                <!-- Thumbnail Images -->
                <div class="grid grid-cols-4 gap-2">
                <% images.forEach((src, i) => { %>
                    <img
                    src="<%= src %>"
                    alt="Thumbnail <%= i + 1 %>"
                    class="rounded-lg cursor-pointer hover:opacity-75 transition"
                    onclick="changeMainImage('<%= src %>')">
                <% }) %>
                </div>
            </div>

            <!-- Right Column - Product Info -->
            <div class="flex flex-col justify-between">
            <div>
                <p class="text-sm text-gray-500 mb-2">Người bán: <%= product.seller_name %></p>
                <% if (product.store_name) { %>
                    <p class="text-sm text-gray-500 mb-2">Cửa hàng: <%= product.store_name %></p>
                <% } %>
                
                <!-- Rating -->
                <div class="flex items-center mb-4">
                    <span class="text-yellow-400">
                        <% const rating = Math.floor(product.seller_rating / 20) || 5; %>
                        <% for (let i = 0; i < 5; i++) { %>
                            <%= i < rating ? '★' : '☆' %>
                        <% } %>
                    </span>
                </div>

                <!-- Price Info -->
                <div class="mb-6">
                    <p class="text-blue-500 text-lg">Giá thầu hiện tại: <span class="font-bold"><%= Number(product.current_price).toLocaleString('vi-VN') %> VND</span></p>
                    <p class="text-red-500 text-xl font-bold">Giá mua ngay: <%= Number(product.buy_now_price || (product.current_price * 1.5)).toLocaleString('vi-VN') %> VND</p>
                </div>

                <!-- Time Remaining -->
                <div class="mb-6">
                    <p class="text-sm text-gray-600 mb-2">Thời gian còn lại</p>
                    <div class="flex gap-2" id="countdown" data-end-time="<%= product.end_time %>">
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="days">00</div>
                            <div class="text-xs">Ngày</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="hours">00</div>
                            <div class="text-xs">Giờ</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="minutes">00</div>
                            <div class="text-xs">Phút</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="seconds">00</div>
                            <div class="text-xs">Giây</div>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Ngày kết thúc: <%= new Date(product.end_time).toLocaleString('vi-VN') %></p>
                </div>

                <!-- Favorite Button -->
                <button onclick="toggleWatchlist('<%= product.id %>')" class="flex items-center gap-2 mb-6 text-gray-700 hover:text-red-500 transition">
                    <span class="text-xl" id="watchlist-icon">☆</span>
                    <span>Yêu thích</span>
                </button>

                <!-- Buy Now -->
                <div class="mb-6">
                    <p class="font-semibold mb-3">Mua ngay</p>
                    <p class="text-sm text-gray-600 mb-2">
                        Mua ngay với giá <b><%= Number(product.buy_now_price || (product.current_price * 1.5)).toLocaleString('vi-VN') %> VND</b>. Hành động này sẽ kết thúc phiên đấu giá.
                    </p>
                    <form method="post" action="/auctions/<%= product.auction_id %>/buy" onsubmit="return confirm('Bạn chắc chắn muốn MUA NGAY sản phẩm này? Phiên đấu giá sẽ kết thúc.');">
                        <button type="submit" class="w-full bg-red-600 text-white rounded px-4 py-2 hover:bg-red-700 transition">
                            Mua ngay
                        </button>
                    </form>
                </div>

                <!-- Auto Bid Options -->
                <div class="mb-6">
                    <p class="font-semibold mb-3">Tự động đấu giá (Auto-bid)</p>
                    <p class="text-sm text-gray-600 mb-2">
                        Nhập mức giá tối đa (<b>nhỏ hơn giá mua ngay</b>). Hệ thống sẽ tự tăng theo <b>bước giá tối thiểu</b> (<%= Number(product.step_price || 0).toLocaleString('vi-VN') %> VND) khi có người vượt bạn, nhưng không vượt quá max.
                    </p>

                    <form onsubmit="setAutoBid(event)">
                        <div class="flex gap-2">
                            <input 
                                type="number" 
                                id="autoBidMax"
                                class="flex-1 border border-gray-300 rounded px-4 py-2"
                                min="<%= Number(product.current_price) %>"
                                max="<%= Math.max(0, Number(product.buy_now_price || (product.current_price * 1.5)) - 1) %>"
                                step="<%= product.step_price %>"
                                value="<%= myAutoBid ? myAutoBid.max_amount : '' %>"
                                placeholder="Nhập giá tối đa (VND)"
                                required
                            />
                            <button type="submit" class="flex-1 bg-gray-900 text-white rounded px-4 py-2 hover:bg-gray-800 transition">
                                Lưu auto-bid
                            </button>
                        </div>
                    </form>

                    <% if (myAutoBid) { %>
                        <p class="text-xs text-gray-500 mt-2">
                            Trạng thái: <b><%= myAutoBid.is_active ? 'Đang bật' : 'Đang tắt' %></b> |
                            Max: <b><%= Number(myAutoBid.max_amount).toLocaleString('vi-VN') %> VND</b>
                        </p>
                    <% } %>
                </div>

                <!-- Ask Question Section -->
                <div class="bg-blue-50 rounded-lg p-6">
                    <h3 class="font-semibold text-lg mb-4">Hỏi người bán</h3>
                    <form onsubmit="askQuestion(event, '<%= product.id %>')">
                        <textarea 
                            id="questionText"
                            class="w-full border border-gray-300 rounded-lg p-3 mb-4 focus:outline-none focus:border-blue-500"
                            rows="4"
                            placeholder="Nhập câu hỏi của bạn..."></textarea>
                        <button type="submit" class="bg-white border border-gray-300 rounded-lg px-6 py-2 hover:bg-gray-50 transition">
                            Gửi câu hỏi
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Auction History Section -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6">Lịch sử đấu thầu</h2>
        
        <!-- Table Headers -->
        <div class="grid grid-cols-4 gap-4 bg-gray-100 p-4 rounded-t-lg font-semibold text-gray-700">
            <div>Người thầu</div>
            <div>Giá cao nhất</div>
            <div>Thời gian đấu thầu</div>
            <div>Biểm danh giá</div>
        </div>

        <!-- Table Rows -->
        <div class="border border-t-0 rounded-b-lg">
            <% if (bids && bids.length > 0) { %>
                <% bids.forEach((bid, index) => { %>
                    <div class="grid grid-cols-4 gap-4 p-4 <%= index < bids.length - 1 ? 'border-b' : '' %> hover:bg-gray-50">
                        <div class="text-gray-600"><%= bid.bidder_masked %></div>
                        <div><%= Number(bid.amount).toLocaleString('vi-VN') %> VND</div>
                        <div class="text-sm text-gray-500"><%= new Date(bid.created_at).toLocaleString('vi-VN') %></div>
                        <div class="text-yellow-400">
                            <% const bidRating = Math.floor((bid.bidder_rating || 50) / 20); %>
                            <% for (let i = 0; i < 5; i++) { %>
                                <%= i < bidRating ? '★' : '☆' %>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="p-8 text-center text-gray-500">
                    Chưa có lượt đấu giá nào
                </div>
            <% } %>
        </div>
    </div>

    <!-- Product Description Section -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-gray-200">Mô tả sản phẩm</h2>
        
        <div class="space-y-6">
            <div>
                <p class="text-gray-700 leading-relaxed whitespace-pre-line">
                    <%= product.full_description || product.short_description || 'Chưa có mô tả chi tiết' %>
                </p>
            </div>
        </div>
    </div>

    <!-- Customer Reviews Section -->
        <div class="px-8 pb-8">
            <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-gray-200">Bình luận</h2>
            
            <div class="space-y-6">
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach((review, idx) => { %>
                        <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
                            <div class="flex-shrink-0">
                                <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center text-white font-bold">
                                    <%= (review.user_name || 'U')[0].toUpperCase() %>
                                </div>
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <h4 class="font-semibold text-gray-800"><%= review.user_name || 'Ẩn danh' %></h4>
                                    <span class="text-yellow-400 text-sm">
                                        <% for (let i = 0; i < review.rating; i++) { %>★<% } %>
                                        <% for (let i = review.rating; i < 5; i++) { %>☆<% } %>
                                    </span>
                                </div>
                                <p class="text-xs text-gray-500 mb-2"><%= new Date(review.created_at).toLocaleString('vi-VN') %></p>
                                <p class="text-gray-700 text-sm leading-relaxed mb-3">
                                    <%= review.comment || 'Không có bình luận' %>
                                </p>
                                <% if (review.images && review.images.length > 0) { %>
                                    <div class="flex gap-2">
                                        <% review.images.forEach((img, i) => { %>
                                            <img src="<%= img %>" alt="Review <%= i + 1 %>" class="w-20 h-20 object-cover rounded" onerror="this.style.display='none'">
                                        <% }) %>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="p-8 text-center text-gray-500">
                        Chưa có bình luận nào
                    </div>
                <% } %>
            </div>
        </div>

    <!-- Related Products Section -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-gray-200">Các sản phẩm khác</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% if (relatedProducts && relatedProducts.length > 0) { %>
                <% relatedProducts.forEach(related => { 
                    const rid = related.id || related.product_id;
                    const imgSrc = related.image && !related.image.includes('placeholder')
                    ? related.image
                    : `/uploads/products/${rid}/0.jpg`;
                %>
                    <div class="border rounded-lg overflow-hidden hover:shadow-lg transition cursor-pointer">
                        <a href="/product/<%= rid %>" class="block">
                            <img src="<%= imgSrc %>" alt="<%= related.title %>" class="w-full h-48 object-cover">
                            <div class="p-4">
                                <h3 class="font-semibold text-gray-800 mb-2 line-clamp-2"><%= related.title %></h3>
                                <p class="text-sm text-gray-600 mb-1">
                                    Giá hiện tại: <span class="font-bold text-red-600">
                                    <%= Number(related.current_price || 0).toLocaleString('vi-VN') %>₫
                                    </span>
                                </p>
                                <p class="text-sm text-green-600 mb-3" data-end-time="<%= related.end_time %>">Đang tính...</p>
                                <button class="w-full bg-white border border-gray-300 text-gray-700 py-2 rounded hover:bg-gray-50 transition">
                                    Xem chi tiết
                                </button>
                            </div>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="col-span-3 text-center text-gray-500 py-8">Không có sản phẩm liên quan</p>
            <% } %>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="bg-white border-t mt-12">
    <div class="max-w-6xl mx-auto px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Logo & Info -->
            <div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-20 h-20 bg-gray-900 flex items-center justify-center">
                        <svg viewBox="0 0 100 100" class="w-16 h-16 fill-white">
                            <text x="50" y="60" font-size="50" font-weight="bold" text-anchor="middle" font-family="Arial">UAE</text>
                        </svg>
                    </div>
                </div>
                <div class="space-y-2 text-sm text-gray-600">
                    <p><strong>THÔNG TIN LIÊN HỆ</strong></p>
                    <p>Hotline: 0123456789</p>
                    <p>Email: baomoc333@gmail.com</p>
                    <p>Địa chỉ: 227 Nguyễn Văn Cừ, Quận 5, TP.HCM</p>
                </div>
            </div>

            <!-- Empty space for balance -->
            <div></div>
        </div>
    </div>

    <!-- Copyright -->
    <div class="bg-blue-400 text-white text-center py-4">
        <p class="font-semibold">@ULP2025</p>
    </div>
</footer>

<script>
    const AUCTION_ID = <%= product.auction_id ? Number(product.auction_id) : 'null' %>;
    const IS_AUTH = <%= user ? 'true' : 'false' %>;

    // Countdown timer
    function updateCountdown() {
        const countdown = document.getElementById('countdown');
        if (!countdown) return;
        
        const endTime = new Date(countdown.getAttribute('data-end-time')).getTime();
        const now = new Date().getTime();
        const distance = endTime - now;

        if (distance < 0) {
            document.getElementById('days').textContent = '00';
            document.getElementById('hours').textContent = '00';
            document.getElementById('minutes').textContent = '00';
            document.getElementById('seconds').textContent = '00';
            return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById('days').textContent = String(days).padStart(2, '0');
        document.getElementById('hours').textContent = String(hours).padStart(2, '0');
        document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
        document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
    }

    // Update related products countdown
    document.querySelectorAll('[data-end-time]').forEach(el => {
        if (el.id === 'countdown') return;
        
        const endTime = new Date(el.getAttribute('data-end-time')).getTime();
        const now = new Date().getTime();
        const distance = endTime - now;

        if (distance < 0) {
            el.textContent = 'Đã kết thúc';
            return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        el.textContent = `Còn ${days} ngày ${hours} giờ`;
    });

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // Change main image
    function changeMainImage(src) {
        document.getElementById('mainImage').src = src;
    }

    // Toggle watchlist
    function toggleWatchlist(productId) {
        const icon = document.getElementById('watchlist-icon');
        icon.textContent = icon.textContent === '☆' ? '★' : '☆';
        // TODO: Implement AJAX call
    }
    // Ask question
    function askQuestion(event, productId) {
        event.preventDefault();
        const question = document.getElementById('questionText').value;
        if (question.trim()) {
            alert('Câu hỏi đã được gửi');
            document.getElementById('questionText').value = '';
        }
        // TODO: Implement AJAX call
    }

    function setAutoBid(event) {
        event.preventDefault();
        if (!IS_AUTH) return window.location.href = '/login';
        if (!AUCTION_ID) return alert('Không tìm thấy phiên đấu giá.');

        const max_amount = Number(document.getElementById('autoBidMax')?.value || 0);
        if (!max_amount || max_amount <= 0) return alert('Vui lòng nhập max hợp lệ.');

        fetch(`/auctions/${AUCTION_ID}/auto-bid`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ max_amount })
        })
        .then(r => r.json().catch(() => ({})).then(d => ({ ok: r.ok, d })))
        .then(({ ok, d }) => {
            if (!ok || !d.success) return alert(d.message || d.error || 'Lưu auto-bid thất bại');
            if (d.note) alert(d.note);
            window.location.reload();
        })
        .catch(() => alert('Lưu auto-bid thất bại'));
    }
</script>
</body>