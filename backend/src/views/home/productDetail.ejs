<% layout('layouts/main') %>

<div class="max-w-6xl mx-auto bg-white rounded-lg shadow-lg overflow-hidden">
        <!-- Header với background gradient -->
        <div class="relative bg-gradient-to-br from-blue-100 via-purple-50 to-pink-50 p-8">
            <!-- Decorative circles -->
            <div class="absolute top-8 right-1/4 w-32 h-32 bg-gradient-to-br from-blue-200 to-transparent rounded-full opacity-50"></div>
            <div class="absolute top-4 right-1/3 w-24 h-24 bg-gradient-to-br from-purple-200 to-transparent rounded-full opacity-40"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 -mt-32 relative z-10">
            <!-- Left Column - Product Images -->
            <div>
                <div class="bg-white rounded-lg p-4 shadow-md mb-4">
                    <img src="<%= product.image %>" alt="<%= product.title %>" class="w-full rounded-lg" id="mainImage">
                </div>
                
                <!-- Thumbnail Images -->
                <div class="grid grid-cols-4 gap-2">
                    <img src="<%= product.image %>" alt="Thumbnail 1" class="rounded-lg cursor-pointer hover:opacity-75 transition" onclick="changeMainImage(this.src)">
                    <img src="<%= product.image %>" alt="Thumbnail 2" class="rounded-lg cursor-pointer hover:opacity-75 transition" onclick="changeMainImage(this.src)">
                    <img src="<%= product.image %>" alt="Thumbnail 3" class="rounded-lg cursor-pointer hover:opacity-75 transition" onclick="changeMainImage(this.src)">
                    <img src="<%= product.image %>" alt="Thumbnail 4" class="rounded-lg cursor-pointer hover:opacity-75 transition" onclick="changeMainImage(this.src)">
                </div>
            </div>

            <!-- Right Column - Product Info -->
            <div>
                <h1 class="text-3xl font-bold text-gray-800 mb-2"><%= product.title %></h1>
                <p class="text-sm text-gray-500 mb-2">Người bán: <%= product.seller_name %></p>
                
                <!-- Rating -->
                <div class="flex items-center mb-4">
                    <span class="text-yellow-400">
                        <% const rating = Math.floor(product.seller_rating / 20) || 5; %>
                        <% for (let i = 0; i < 5; i++) { %>
                            <%= i < rating ? '★' : '☆' %>
                        <% } %>
                    </span>
                </div>

                <!-- Price Info -->
                <div class="mb-6">
                    <p class="text-blue-500 text-lg">Giá thầu hiện tại: <span class="font-bold"><%= Number(product.current_price).toLocaleString('vi-VN') %> VND</span></p>
                    <p class="text-red-500 text-xl font-bold">Giá mua ngay: <%= Number(product.current_price * 1.5).toLocaleString('vi-VN') %> VND</p>
                </div>

                <!-- Time Remaining -->
                <div class="mb-6">
                    <p class="text-sm text-gray-600 mb-2">Thời gian còn lại</p>
                    <div class="flex gap-2" id="countdown" data-end-time="<%= product.end_time %>">
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="days">00</div>
                            <div class="text-xs">Ngày</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="hours">00</div>
                            <div class="text-xs">Giờ</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="minutes">00</div>
                            <div class="text-xs">Phút</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="seconds">00</div>
                            <div class="text-xs">Giây</div>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Ngày kết thúc: <%= new Date(product.end_time).toLocaleString('vi-VN') %></p>
                </div>

                <!-- Favorite Button -->
                <button onclick="toggleWatchlist('<%= product.id %>')" class="flex items-center gap-2 mb-6 text-gray-700 hover:text-red-500 transition">
                    <span class="text-xl" id="watchlist-icon">☆</span>
                    <span>Yêu thích</span>
                </button>

                <!-- Bid Options -->
                <div class="mb-6">
                    <p class="font-semibold mb-3">Giá cược của bạn</p>
                    <form onsubmit="placeBid(event, '<%= product.id %>')">
                        <div class="flex gap-2">
                            <input 
                                type="number" 
                                id="bidAmount"
                                class="flex-1 border border-gray-300 rounded px-4 py-2"
                                min="<%= Number(product.current_price) + Number(product.step_price) %>"
                                step="<%= product.step_price %>"
                                placeholder="Nhập giá đấu"
                            />
                            <button type="submit" class="flex-1 bg-blue-600 text-white rounded px-4 py-2 hover:bg-blue-700 transition">Đặt giá</button>
                        </div>
                    </form>
                </div>

                <!-- Ask Question Section -->
                <div class="bg-blue-50 rounded-lg p-6">
                    <h3 class="font-semibold text-lg mb-4">Hỏi người bán</h3>
                    <form onsubmit="askQuestion(event, '<%= product.id %>')">
                        <textarea 
                            id="questionText"
                            class="w-full border border-gray-300 rounded-lg p-3 mb-4 focus:outline-none focus:border-blue-500"
                            rows="4"
                            placeholder="Nhập câu hỏi của bạn..."></textarea>
                        <button type="submit" class="bg-white border border-gray-300 rounded-lg px-6 py-2 hover:bg-gray-50 transition">
                            Gửi câu hỏi
                        </button>
                    </form>
                </div>
            </div>
        </div>

