<% layout('layouts/main') %>

    <div class="relative bg-gradient-to-br from-blue-100 via-purple-50 to-pink-50 p-6 overflow-hidden">

            <!-- Background decorations (LUON o SAU) -->
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute top-8 right-1/4 w-32 h-32 bg-gradient-to-br from-blue-200 to-transparent rounded-full opacity-50"></div>
                <div class="absolute top-4 right-1/3 w-24 h-24 bg-gradient-to-br from-purple-200 to-transparent rounded-full opacity-40"></div>
            </div>

            <!-- Title -->
            <h1 class="text-2xl font-bold text-gray-800 text">
                <%= product.title %>
            </h1>
        </div>

         <div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 mt-6 relative z-40">
            <!-- Left Column - Product Images -->
            <div>
                <% const images = (product.images && product.images.length) ? product.images : [product.image].filter(Boolean); %>
                <div class="bg-white rounded-lg p-4 shadow-md mb-4">
                <img src="<%= images[0] %>" alt="<%= product.title %>" class="w-full rounded-lg" id="mainImage">
                </div>

                <!-- Thumbnail Images -->
                <div class="grid grid-cols-4 gap-2">
                <% images.forEach((src, i) => { %>
                    <img
                    src="<%= src %>"
                    alt="Thumbnail <%= i + 1 %>"
                    class="rounded-lg cursor-pointer hover:opacity-75 transition"
                    onclick="changeMainImage('<%= src %>')">
                <% }) %>
                </div>
            </div>

            <!-- Right Column - Product Info -->
            <div class="flex flex-col justify-between">
            <div>
                <p class="text-sm text-gray-500 mb-2">Người bán: <%= product.seller_name %></p>
                <% if (product.store_name) { %>
                    <p class="text-sm text-gray-500 mb-2">Cửa hàng: <%= product.store_name %></p>
                <% } %>
                
                <!-- Rating -->
                <div class="flex items-center mb-4">
                    <span class="text-yellow-400">
                        <% const rating = Math.floor(product.seller_rating / 20) || 5; %>
                        <% for (let i = 0; i < 5; i++) { %>
                            <%= i < rating ? '★' : '☆' %>
                        <% } %>
                    </span>
                </div>

                <!-- Price Info -->
                <div class="mb-6">
                    <p class="text-blue-500 text-lg">Giá thầu hiện tại: <span class="font-bold"><%= Number(product.current_price).toLocaleString('vi-VN') %> VND</span></p>
                    <p class="text-red-500 text-xl font-bold">Giá mua ngay: <%= Number(product.buy_now_price || (product.current_price * 1.5)).toLocaleString('vi-VN') %> VND</p>
                </div>

                <!-- Time Remaining -->
                <div class="mb-6">
                    <p class="text-sm text-gray-600 mb-2">Thời gian còn lại</p>
                    <div class="flex gap-2" id="countdown" data-end-time="<%= product.end_time %>" data-end-ms="<%= product.end_time_ms %>">
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="days">00</div>
                            <div class="text-xs">Ngày</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="hours">00</div>
                            <div class="text-xs">Giờ</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="minutes">00</div>
                            <div class="text-xs">Phút</div>
                        </div>
                        <div class="bg-teal-800 text-white px-4 py-3 rounded text-center">
                            <div class="text-2xl font-bold" id="seconds">00</div>
                            <div class="text-xs">Giây</div>
                        </div>
                    </div>
                    <% if (product.status === 'ENDED' && product.winner_id) { %>
                        <div class="bg-green-100 border border-green-400 text-green-800 rounded p-4 mb-4 mt-6">
                            <b>Phiên đấu giá đã kết thúc.</b>
                            <div class="mt-2">
                                Người thắng: <%= product.winner_name || 'Ẩn danh' %>
                            </div>
                            <% if (user && user.id === product.winner_id) { %>
                                <div class="mt-3">
                                    <% if (product.hasRated) { %>
                                        <div class="p-3 bg-blue-100 border border-blue-300 text-blue-800 rounded mb-2">
                                            Bạn đã đánh giá người bán.
                                        </div>
                                    <% } else { %>
                                        <form method="post" action="/auctions/<%= product.auction_id %>/rate-seller">
                                            <label class="block mb-2 font-semibold">Nhận xét người bán:</label>
                                            <textarea name="comment" class="w-full border rounded p-2 mb-2" rows="3" required></textarea>
                                            <div class="flex gap-2 items-center mb-2">
                                                <label><input type="radio" name="rating" value="1" required> 👍 Like</label>
                                                <label><input type="radio" name="rating" value="-1" required> 👎 Dislike</label>
                                            </div>
                                            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Gửi nhận xét</button>
                                        </form>
                                    <% } %>
                                </div>
                            <% } %>
                            <p class="text-xs text-gray-500 mt-2">Ngày kết thúc: <%= new Date(product.end_time).toLocaleString('vi-VN') %></p>
                        </div>
                    <% } %>

                <!-- Favorite Button -->
                <button onclick="toggleWatchlist()" class="flex items-center gap-2 mb-6 text-gray-700 hover:text-red-500 transition">
                    <span class="text-xl" id="watchlist-icon">☆</span>
                    <span>Yêu thích</span>
                </button>

                <% if (typeof interaction !== 'undefined' && interaction && interaction.blocked) { %>
                  <div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 rounded">
                    <div class="font-semibold mb-1">Bạn không thể thao tác với sản phẩm này</div>
                    <div class="text-sm"><%= interaction.reason || 'Bạn đã bị chặn khỏi phiên đấu giá này.' %></div>
                  </div>
                <% } else if (typeof interaction !== 'undefined' && interaction && interaction.reputation !== null) { %>
                  <div class="mb-6 p-3 bg-slate-50 border border-slate-200 text-slate-700 rounded">
                    <div class="text-sm">
                      Điểm uy tín hiện tại: <b><%= interaction.reputation %></b>.
                      <% if (interaction.allow_negative_user) { %>
                        Sản phẩm này <b>cho phép</b> user điểm uy tín thấp (&lt; 5) tham gia.
                      <% } else { %>
                        Sản phẩm này <b>không cho phép</b> user điểm uy tín thấp (&lt; 5) tham gia.
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <!-- Buy Now -->
                <div class="mb-6">
                    <p class="font-semibold mb-3">Mua ngay</p>
                    <p class="text-sm text-gray-600 mb-2">
                        Mua ngay với giá <b><%= Number(product.buy_now_price || (product.current_price * 1.5)).toLocaleString('vi-VN') %> VND</b>. Hành động này sẽ kết thúc phiên đấu giá.
                    </p>
                    <form method="post" action="/auctions/<%= product.auction_id %>/buy" onsubmit="return openPaymentModal(event, 'buyNow');">
                        <button 
                            type="submit" 
                            id="buyNowBtn"
                            <%= (typeof interaction !== 'undefined' && interaction && interaction.blocked) ? 'disabled' : '' %>
                            class="w-full bg-red-600 text-white rounded px-4 py-2 hover:bg-red-700 transition disabled:bg-gray-400 disabled:cursor-not-allowed"
                            data-end-time="<%= product.end_time %>">
                            Mua ngay
                        </button>
                    </form>
                </div>

                <!-- Auto Bid Options -->
                <div class="mb-6">
                    <p class="font-semibold mb-3">Tự động đấu giá (Auto-bid)</p>
                    <p class="text-sm text-gray-600 mb-2">
                        Nhập mức giá tối đa (<b>nhỏ hơn giá mua ngay</b>). Hệ thống sẽ tự tăng theo <b>bước giá tối thiểu</b> (<%= Number(product.step_price || 0).toLocaleString('vi-VN') %> VND) khi có người vượt bạn, nhưng không vượt quá max.
                    </p>

                    <form onsubmit="return openPaymentModal(event, 'autoBid');">
                        <div class="flex gap-2">
                            <input 
                                type="number" 
                                id="autoBidMax"
                                <%= (typeof interaction !== 'undefined' && interaction && interaction.blocked) ? 'disabled' : '' %>
                                class="flex-1 border border-gray-300 rounded px-4 py-2 disabled:bg-gray-100 disabled:cursor-not-allowed"
                                min="<%= Number(product.current_price) %>"
                                max="<%= Math.max(0, Number(product.buy_now_price || (product.current_price * 1.5)) - 1) %>"
                                step="<%= product.step_price %>"
                                value="<%= myAutoBid ? myAutoBid.max_amount : '' %>"
                                placeholder="Nhập giá tối đa (VND)"
                                required
                                data-end-time="<%= product.end_time %>"
                            />
                            <button 
                                type="submit" 
                                id="autoBidBtn"
                                <%= (typeof interaction !== 'undefined' && interaction && interaction.blocked) ? 'disabled' : '' %>
                                class="flex-1 bg-gray-900 text-white rounded px-4 py-2 hover:bg-gray-800 transition disabled:bg-gray-400 disabled:cursor-not-allowed"
                                data-end-time="<%= product.end_time %>">
                                Lưu auto-bid
                            </button>
                        </div>
                    </form>

                    <% if (myAutoBid) { %>
                        <p class="text-xs text-gray-500 mt-2">
                            Trạng thái: <b><%= myAutoBid.is_active ? 'Đang bật' : 'Đang tắt' %></b> |
                            Max: <b><%= Number(myAutoBid.max_amount).toLocaleString('vi-VN') %> VND</b>
                        </p>
                    <% } %>
                </div>

                <!-- Ask Question Section -->
                <div class="bg-blue-50 rounded-lg p-6">
                    <h3 class="font-semibold text-lg mb-4">Hỏi người bán</h3>
                    <form onsubmit="askQuestion(event, '<%= product.id %>')">
                        <textarea 
                            id="questionText"
                            class="w-full border border-gray-300 rounded-lg p-3 mb-4 focus:outline-none focus:border-blue-500"
                            rows="4"
                            placeholder="Nhập câu hỏi của bạn..."></textarea>
                        <button type="submit" class="bg-white border border-gray-300 rounded-lg px-6 py-2 hover:bg-gray-50 transition">
                            Gửi câu hỏi
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Auction History Section -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6">Lịch sử đấu thầu</h2>
        
        <!-- Table Headers -->
        <div class="grid grid-cols-4 <%= user && user.id === product.seller_id ? 'md:grid-cols-5' : '' %> gap-4 bg-gray-100 p-4 rounded-t-lg font-semibold text-gray-700">
            <div>Người thầu</div>
            <div>Giá cao nhất</div>
            <div>Thời gian đấu thầu</div>
            <div>Biểm danh giá</div>
            <% if (user && user.id === product.seller_id) { %>
                <div>Hành động</div>
            <% } %>
        </div>

        <!-- Table Rows -->
        <div class="border border-t-0 rounded-b-lg">
            <% if (bids && bids.length > 0) { %>
                <% bids.forEach((bid, index) => { %>
                    <div class="grid grid-cols-4 <%= user && user.id === product.seller_id ? 'md:grid-cols-5' : '' %> gap-4 p-4 <%= index < bids.length - 1 ? 'border-b' : '' %> hover:bg-gray-50">
                        <div class="text-gray-600"><%= bid.bidder_masked %></div>
                        <div><%= Number(bid.amount).toLocaleString('vi-VN') %> VND</div>
                        <div class="text-sm text-gray-500"><%= new Date(bid.created_at).toLocaleString('vi-VN') %></div>
                        <div class="text-yellow-400">
                            <% const bidRating = Math.floor((bid.bidder_rating || 50) / 20); %>
                            <% for (let i = 0; i < 5; i++) { %>
                                <%= i < bidRating ? '★' : '☆' %>
                            <% } %>
                        </div>
                        <% if (user && user.id === product.seller_id) { %>
                            <div>
                                <button class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-700 transition"
                                    onclick="rejectBidder(<%= bid.bidder_id %>, <%= product.auction_id %>)">
                                    Từ chối
                                </button>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="p-8 text-center text-gray-500">
                    Chưa có lượt đấu giá nào
                </div>
            <% } %>
        </div>
    </div>

    <!-- Product Description Section -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-gray-200">Mô tả sản phẩm</h2>
        <div class="space-y-6">
            <% if (product.full_description) { %>
                <div class="whitespace-pre-line">
                    <%= product.full_description %>
                </div>
            <% } else { %>
                <div class="text-gray-500">Chưa có mô tả</div>
            <% } %>
        </div>
    </div>

    <!-- Customer Reviews Section (dùng Q&A) -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-gray-200">Bình luận</h2>
        
        <div class="space-y-4">
            <% if (qnas && qnas.length > 0) { %>
                <% qnas.forEach((qa) => { 
                    const initials = (qa.user_name || 'Ẩn danh').trim().split(' ').map(s => s[0]).join('').slice(0,2).toUpperCase();
                %>
                    <div class="border border-gray-200 bg-white rounded-xl shadow-sm hover:shadow-md transition p-5">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-blue-500 text-white flex items-center justify-center font-semibold">
                                <%= initials %>
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-1">
                                    <p class="font-semibold text-gray-900"><%= qa.user_name || 'Ẩn danh' %></p>
                                    <% if (qa.answer) { %>
                                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full bg-green-100 text-green-700">
                                            Đã trả lời
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-700">
                                            Chờ trả lời
                                        </span>
                                    <% } %>
                                </div>
                                <p class="text-xs text-gray-500 mb-3"><%= new Date(qa.created_at).toLocaleString('vi-VN') %></p>
                                <p class="text-gray-800 mb-3"><span class="font-semibold">Hỏi:</span> <%= qa.question %></p>

                                <% if (qa.answer) { %>
                                    <div class="mt-3 pl-4 border-l-4 border-green-400 bg-green-50 rounded-lg py-3">
                                        <p class="text-sm font-semibold text-green-800 mb-1">Trả lời từ người bán</p>
                                        <p class="text-gray-700 text-sm"><%= qa.answer %></p>
                                        <p class="text-xs text-gray-500 mt-2"><%= new Date(qa.answered_at).toLocaleString('vi-VN') %></p>
                                    </div>
                                <% } else { %>
                                    <p class="text-sm text-gray-500 italic">Chờ trả lời...</p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="p-8 text-center text-gray-500 bg-gray-50 rounded-xl border border-dashed border-gray-200">
                    Chưa có câu hỏi nào
                </div>
            <% } %>
        </div>

        <% if (qnaPagination && qnaPagination.totalPages > 1) { %>
            <div class="flex items-center justify-between mt-6 text-sm">
                <% const prev = Math.max(1, qnaPagination.page - 1); %>
                <% const next = Math.min(qnaPagination.totalPages, qnaPagination.page + 1); %>
                <a class="px-3 py-2 border rounded <%= qnaPagination.page === 1 ? 'pointer-events-none opacity-50' : '' %>"
                href="?qpage=<%= prev %>">« Trước</a>
                <span>Trang <%= qnaPagination.page %> / <%= qnaPagination.totalPages %> · <%= qnaPagination.total %> bình luận</span>
                <a class="px-3 py-2 border rounded <%= qnaPagination.page === qnaPagination.totalPages ? 'pointer-events-none opacity-50' : '' %>"
                href="?qpage=<%= next %>">Sau »</a>
            </div>
        <% } %>
    </div>

    <!-- Login Modal -->
    <div id="loginModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg p-8 max-w-md w-full relative">
            <button onclick="closeLoginModal()" class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 text-2xl">×</button>
            
            <h2 class="text-2xl font-bold mb-4 text-gray-800">Đăng nhập để tiếp tục</h2>
            <p class="text-gray-600 mb-6">Vui lòng đăng nhập hoặc đăng ký để gửi câu hỏi</p>
            
            <div class="space-y-3">
                <a href="/login" class="block w-full bg-blue-600 text-white rounded-lg px-4 py-3 text-center hover:bg-blue-700 transition font-semibold">
                    Đăng nhập
                </a>
                <a href="/register" class="block w-full bg-gray-200 text-gray-800 rounded-lg px-4 py-3 text-center hover:bg-gray-300 transition font-semibold">
                    Đăng ký
                </a>
            </div>
        </div>
    </div>

    <!-- Related Products Section -->
    <div class="px-8 pb-8">
        <h2 class="text-2xl font-bold mb-6 pb-2 border-b-2 border-gray-200">Các sản phẩm khác</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% if (relatedProducts && relatedProducts.length > 0) { %>
                <% relatedProducts.forEach(related => { 
                    const rid = related.id || related.product_id;
                    const imgSrc = related.image && !related.image.includes('placeholder')
                    ? related.image
                    : `/uploads/products/${rid}/0.jpg`;
                %>
                    <div class="border rounded-lg overflow-hidden hover:shadow-lg transition cursor-pointer">
                        <a href="/product/<%= rid %>" class="block">
                            <img src="<%= imgSrc %>" alt="<%= related.title %>" class="w-full h-48 object-cover">
                            <div class="p-4">
                                <h3 class="font-semibold text-gray-800 mb-2 line-clamp-2"><%= related.title %></h3>
                                <p class="text-sm text-gray-600 mb-1">
                                    Giá hiện tại: <span class="font-bold text-red-600">
                                    <%= Number(related.current_price || 0).toLocaleString('vi-VN') %>₫
                                    </span>
                                </p>
                                <p class="text-sm text-green-600 mb-3" data-end-time="<%= related.end_time %>">Đang tính...</p>
                                <button class="w-full bg-white border border-gray-300 text-gray-700 py-2 rounded hover:bg-gray-50 transition">
                                    Xem chi tiết
                                </button>
                            </div>
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="col-span-3 text-center text-gray-500 py-8">Không có sản phẩm liên quan</p>
            <% } %>
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="bg-white border-t mt-12">
    <div class="max-w-6xl mx-auto px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Logo & Info -->
            <div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-20 h-20 bg-gray-900 flex items-center justify-center">
                        <svg viewBox="0 0 100 100" class="w-16 h-16 fill-white">
                            <text x="50" y="60" font-size="50" font-weight="bold" text-anchor="middle" font-family="Arial">UAE</text>
                        </svg>
                    </div>
                </div>
                <div class="space-y-2 text-sm text-gray-600">
                    <p><strong>THÔNG TIN LIÊN HỆ</strong></p>
                    <p>Hotline: 0123456789</p>
                    <p>Email: baomoc333@gmail.com</p>
                    <p>Địa chỉ: 227 Nguyễn Văn Cừ, Quận 5, TP.HCM</p>
                </div>
            </div>

            <!-- Empty space for balance -->
            <div></div>
        </div>
    </div>

    <!-- Copyright -->
    <div class="bg-blue-400 text-white text-center py-4">
        <p class="font-semibold">@ULP2025</p>
    </div>
</footer>


    <!-- Demo Payment Modal -->
    <div id="paymentModal" class="fixed inset-0 hidden z-50">
        <div class="absolute inset-0 bg-black/50" onclick="closePaymentModal()"></div>
        <div class="relative mx-auto mt-24 w-[92%] max-w-md bg-white rounded-xl shadow-lg p-6">
            <h3 id="paymentTitle" class="text-lg font-semibold mb-2">Xác nhận thanh toán</h3>
            <p id="paymentDesc" class="text-sm text-gray-600 mb-4"></p>

            <div class="flex justify-center mb-3">
                <!-- QR DEMO (SVG) -->
                <svg width="180" height="180" viewBox="0 0 180 180" class="border border-gray-200 rounded">
                    <rect width="180" height="180" fill="#fff"/>
                    <!-- Finder patterns -->
                    <rect x="10" y="10" width="50" height="50" fill="#000"/>
                    <rect x="18" y="18" width="34" height="34" fill="#fff"/>
                    <rect x="26" y="26" width="18" height="18" fill="#000"/>

                    <rect x="120" y="10" width="50" height="50" fill="#000"/>
                    <rect x="128" y="18" width="34" height="34" fill="#fff"/>
                    <rect x="136" y="26" width="18" height="18" fill="#000"/>

                    <rect x="10" y="120" width="50" height="50" fill="#000"/>
                    <rect x="18" y="128" width="34" height="34" fill="#fff"/>
                    <rect x="26" y="136" width="18" height="18" fill="#000"/>

                    <!-- Random modules (demo) -->
                    <g fill="#000">
                        <rect x="70" y="20" width="10" height="10"/>
                        <rect x="90" y="20" width="10" height="10"/>
                        <rect x="70" y="40" width="10" height="10"/>
                        <rect x="80" y="50" width="10" height="10"/>
                        <rect x="90" y="60" width="10" height="10"/>
                        <rect x="60" y="70" width="10" height="10"/>
                        <rect x="80" y="70" width="10" height="10"/>
                        <rect x="100" y="70" width="10" height="10"/>
                        <rect x="70" y="90" width="10" height="10"/>
                        <rect x="90" y="90" width="10" height="10"/>
                        <rect x="110" y="90" width="10" height="10"/>
                        <rect x="70" y="110" width="10" height="10"/>
                        <rect x="90" y="110" width="10" height="10"/>
                        <rect x="110" y="110" width="10" height="10"/>
                        <rect x="130" y="110" width="10" height="10"/>
                        <rect x="70" y="130" width="10" height="10"/>
                        <rect x="90" y="130" width="10" height="10"/>
                        <rect x="110" y="130" width="10" height="10"/>
                        <rect x="130" y="130" width="10" height="10"/>
                        <rect x="150" y="130" width="10" height="10"/>
                    </g>
                    <text x="90" y="175" text-anchor="middle" font-size="10" fill="#666">QR DEMO</text>
                </svg>
            </div>

            <p class="text-xs text-gray-500 text-center mb-4">
                Đây là thanh toán demo. Bấm “Xác nhận đã thanh toán” để tiếp tục.
            </p>

            <div class="flex gap-2">
                <button type="button"
                        class="flex-1 border border-gray-300 rounded px-4 py-2 hover:bg-gray-50 transition"
                        onclick="closePaymentModal()">
                    Hủy
                </button>
                <button type="button"
                        id="paymentConfirmBtn"
                        class="flex-1 bg-gray-900 text-white rounded px-4 py-2 hover:bg-gray-800 transition"
                        onclick="confirmPayment()">
                    Xác nhận đã thanh toán
                </button>
            </div>
        </div>
    </div>

    <!-- Shipping Address Modal (required before payment) -->
    <div id="shippingModal" class="fixed inset-0 hidden z-50">
        <div class="absolute inset-0 bg-black/50" onclick="closeShippingModal()"></div>
        <div class="relative mx-auto mt-20 w-[92%] max-w-lg bg-white rounded-xl shadow-lg p-6">
            <h3 class="text-lg font-semibold mb-1">Địa chỉ giao hàng</h3>
            <p class="text-sm text-gray-600 mb-4">
                Vui lòng nhập địa chỉ giao hàng trước khi thanh toán.
            </p>

            <div class="space-y-3">
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1" for="shipFullName">Họ và tên người nhận</label>
                    <input id="shipFullName" type="text" class="w-full border border-gray-300 rounded px-3 py-2 text-sm" placeholder="Nguyễn Văn A" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1" for="shipPhone">Số điện thoại</label>
                    <input id="shipPhone" type="tel" class="w-full border border-gray-300 rounded px-3 py-2 text-sm" placeholder="09xxxxxxxx" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1" for="shipAddress">Địa chỉ</label>
                    <textarea id="shipAddress" rows="3" class="w-full border border-gray-300 rounded px-3 py-2 text-sm" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-700 mb-1" for="shipNote">Ghi chú (tuỳ chọn)</label>
                    <input id="shipNote" type="text" class="w-full border border-gray-300 rounded px-3 py-2 text-sm" placeholder="Ví dụ: Giao giờ hành chính" />
                </div>
            </div>

            <div class="mt-5 flex gap-2">
                <button type="button"
                        class="flex-1 border border-gray-300 rounded px-4 py-2 hover:bg-gray-50 transition"
                        onclick="closeShippingModal()">
                    Hủy
                </button>
                <button type="button"
                        id="shippingContinueBtn"
                        class="flex-1 bg-blue-600 text-white rounded px-4 py-2 hover:bg-blue-700 transition"
                        onclick="confirmShippingAndProceed()">
                    Tiếp tục thanh toán
                </button>
            </div>
        </div>
    </div>


<script>
    const AUCTION_ID = <%= product.auction_id ? Number(product.auction_id) : 'null' %>;
    const IS_AUTH = <%= user ? 'true' : 'false' %>;
    const IS_WATCHLISTED = <%= (typeof isWatchlisted !== 'undefined' && isWatchlisted) ? 'true' : 'false' %>;
    const USER_ID = <%= user ? Number(user.id) : 'null' %>;
    const PRODUCT_ID = <%= product.id %>;
    const HAD_AUTOBID = <%= myAutoBid ? 'true' : 'false' %>;
    const BUY_NOW_PRICE = <%= Number(product.buy_now_price || (product.current_price * 1.5)) %>;
    const IS_INTERACTION_BLOCKED = <%= (typeof interaction !== 'undefined' && interaction && interaction.blocked) ? 'true' : 'false' %>;
    const INTERACTION_BLOCK_REASON = <%- JSON.stringify((typeof interaction !== 'undefined' && interaction && interaction.reason) ? interaction.reason : '') %>;


    let __pendingPaymentAction = null;
    let __pendingShippingAddress = null;
    let __pendingShippingAction = null;

    const SHIPPING_STORAGE_KEY = `auction_default_shipping_v1:${USER_ID || 'guest'}`;

    function getSavedShippingAddress() {
        try {
            const raw = window.localStorage ? localStorage.getItem(SHIPPING_STORAGE_KEY) : null;
            if (!raw) return null;
            const obj = JSON.parse(raw);
            if (!obj || typeof obj !== 'object') return null;
            return obj;
        } catch (e) {
            return null;
        }
    }

    function saveShippingAddress(addr) {
        try {
            if (window.localStorage) localStorage.setItem(SHIPPING_STORAGE_KEY, JSON.stringify(addr));
        } catch (e) {
            // ignore
        }
    }

    function openShippingModal(action, prefill) {
        __pendingShippingAction = action;
        const modal = document.getElementById('shippingModal');
        if (!modal) return;

        const fullName = document.getElementById('shipFullName');
        const phone = document.getElementById('shipPhone');
        const address = document.getElementById('shipAddress');
        const note = document.getElementById('shipNote');

        const src = prefill || {};
        if (fullName) fullName.value = src.fullName || '';
        if (phone) phone.value = src.phone || '';
        if (address) address.value = src.address || '';
        if (note) note.value = src.note || '';

        modal.classList.remove('hidden');
    }

    function closeShippingModal() {
        const modal = document.getElementById('shippingModal');
        if (modal) modal.classList.add('hidden');
        __pendingShippingAction = null;
        // do not clear __pendingShippingAddress; user may already have one
    }

    function confirmShippingAndProceed() {
        const action = __pendingShippingAction;
        const fullName = (document.getElementById('shipFullName')?.value || '').trim();
        const phone = (document.getElementById('shipPhone')?.value || '').trim();
        const address = (document.getElementById('shipAddress')?.value || '').trim();
        const note = (document.getElementById('shipNote')?.value || '').trim();

        if (!fullName || !phone || !address) {
            alert('Vui lòng nhập đầy đủ Họ tên, SĐT và Địa chỉ giao hàng.');
            return;
        }

        // Confirmation step (as requested)
        const ok = window.confirm(
            `Xác nhận địa chỉ giao hàng:\n\n` +
            `Người nhận: ${fullName}\n` +
            `SĐT: ${phone}\n` +
            `Địa chỉ: ${address}` +
            (note ? `\nGhi chú: ${note}` : '') +
            `\n\nBạn chắc chắn muốn dùng địa chỉ này để tiếp tục thanh toán?`
        );
        if (!ok) return;

        __pendingShippingAddress = { fullName, phone, address, note };
        saveShippingAddress(__pendingShippingAddress);

        closeShippingModal();
        // proceed to payment modal for the previously requested action
        showPaymentModal(action);
    }

    function showPaymentModal(action) {
        __pendingPaymentAction = action;

        const modal = document.getElementById('paymentModal');
        const title = document.getElementById('paymentTitle');
        const desc  = document.getElementById('paymentDesc');

        if (action === 'autoBid') {
            const max_amount = Number(document.getElementById('autoBidMax')?.value || 0);
            if (!max_amount || max_amount <= 0) {
                alert('Vui lòng nhập max hợp lệ.');
                return false;
            }
            title.textContent = 'Xác nhận thanh toán Auto-bid';
            desc.textContent = HAD_AUTOBID
                ? `Thanh toán demo để cập nhật auto-bid. Max mới: ${max_amount.toLocaleString('vi-VN')} VND. Sau khi thanh toán sẽ hoàn tiền auto-bid trước đó.`
                : `Thanh toán demo để kích hoạt auto-bid. Max: ${max_amount.toLocaleString('vi-VN')} VND.`;
        } else if (action === 'buyNow') {
            title.textContent = 'Xác nhận thanh toán Mua ngay';
            desc.textContent = `Thanh toán demo để mua ngay sản phẩm với giá ${BUY_NOW_PRICE.toLocaleString('vi-VN')} VND. Hành động này sẽ kết thúc phiên đấu giá.`;
        } else {
            title.textContent = 'Xác nhận thanh toán';
            desc.textContent = '';
        }

        modal.classList.remove('hidden');
        return false;
    }


    function openPaymentModal(event, action) {
        if (event && event.preventDefault) event.preventDefault();

        if (!IS_AUTH) {
            window.location.href = '/login';
            return false;
        }
        if (!AUCTION_ID) {
            alert('Không tìm thấy phiên đấu giá.');
            return false;
        }

        if (IS_INTERACTION_BLOCKED) {
            alert(INTERACTION_BLOCK_REASON || 'Bạn không thể thao tác với sản phẩm này.');
            return false;
        }

        // Step 1: collect/confirm shipping address before showing payment QR
        const saved = getSavedShippingAddress();

        if (action === 'autoBid') {
            const max_amount = Number(document.getElementById('autoBidMax')?.value || 0);
            if (!max_amount || max_amount <= 0) {
                alert('Vui lòng nhập max hợp lệ.');
                return false;
            }

            // If updating autobid, ask whether user wants to update address
            if (HAD_AUTOBID && saved) {
                const wantsUpdate = window.confirm('Bạn có muốn cập nhật địa chỉ giao hàng trước khi thanh toán Auto-bid không?');
                if (wantsUpdate) {
                    openShippingModal(action, saved);
                } else {
                    __pendingShippingAddress = saved;
                    showPaymentModal(action);
                }
                return false;
            }

            // First-time autobid OR no saved address => require address
            openShippingModal(action, saved || null);
            return false;
        }

        // Buy-now always requires address confirmation (prefill if any)
        if (action === 'buyNow') {
            openShippingModal(action, saved || null);
            return false;
        }

        // fallback
        showPaymentModal(action);
        return false;
    }

    function closePaymentModal() {
        const modal = document.getElementById('paymentModal');
        if (modal) modal.classList.add('hidden');
        __pendingPaymentAction = null;
    }

    async function confirmPayment() {
        const btn = document.getElementById('paymentConfirmBtn');
        if (btn) btn.disabled = true;

        try {
            if (__pendingPaymentAction === 'autoBid') {
                await apiSetAutoBidAfterPayment();
            } else if (__pendingPaymentAction === 'buyNow') {
                await apiBuyNowAfterPayment();
            } else {
                closePaymentModal();
            }
        } finally {
            if (btn) btn.disabled = false;
        }
    }

    async function apiSetAutoBidAfterPayment() {
        const max_amount = Number(document.getElementById('autoBidMax')?.value || 0);

        const res = await fetch(`/auctions/${AUCTION_ID}/auto-bid`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ max_amount })
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) {
            alert(data.message || data.error || 'Lưu auto-bid thất bại');
            return;
        }

        closePaymentModal();

        if (HAD_AUTOBID) {
            alert('Đã thanh toán AutoBid thành công và đã hoàn tiền AutoBid trước đó (demo).');
        } else {
            alert('Đã thanh toán AutoBid thành công (demo).');
        }

        if (data.note) alert(data.note);

        window.location.reload();
    }

    async function apiBuyNowAfterPayment() {
        const res = await fetch(`/auctions/${AUCTION_ID}/buy`, {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
            credentials: 'same-origin'
            ,
            body: JSON.stringify({ buyer_info: __pendingShippingAddress || null })
        });

        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) {
            alert(data.message || 'Mua ngay thất bại');
            return;
        }

        closePaymentModal();

        alert('Đã mua sản phẩm thành công (demo).');
        // Sửa lại chỉ reload trang sản phẩm chi tiết
        window.location.reload();
    }


    // Countdown timer
    function updateCountdown() {
        const countdown = document.getElementById('countdown');
        if (!countdown) return;
        
        const endMsAttr = Number(countdown.getAttribute("data-end-ms"));
        const endTime = Number.isFinite(endMsAttr) && endMsAttr > 0
          ? endMsAttr
          : new Date(countdown.getAttribute("data-end-time")).getTime();
        const now = new Date().getTime();
        const distance = endTime - now;

        if (distance < 0) {
            document.getElementById('days').textContent = '00';
            document.getElementById('hours').textContent = '00';
            document.getElementById('minutes').textContent = '00';
            document.getElementById('seconds').textContent = '00';
            disableAuctionButtons(); // Disable nút khi hết giờ
            return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById('days').textContent = String(days).padStart(2, '0');
        document.getElementById('hours').textContent = String(hours).padStart(2, '0');
        document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
        document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
    }

    // Disable auction buttons khi hết giờ
    function disableAuctionButtons() {
        const buyNowBtn = document.getElementById('buyNowBtn');
        const autoBidBtn = document.getElementById('autoBidBtn');
        const autoBidInput = document.getElementById('autoBidMax');

        if (buyNowBtn) {
            buyNowBtn.disabled = true;
            buyNowBtn.textContent = 'Phiên đấu giá đã kết thúc';
        }
        if (autoBidBtn) {
            autoBidBtn.disabled = true;
            autoBidBtn.textContent = 'Phiên đã kết thúc';
        }
        if (autoBidInput) {
            autoBidInput.disabled = true;
        }
    }

    // Check on page load
    function checkAuctionStatus() {
        const c = document.getElementById("countdown");
        const endMsAttr = Number(c?.getAttribute("data-end-ms"));
        const endTime = Number.isFinite(endMsAttr) && endMsAttr > 0
          ? endMsAttr
          : new Date(c?.getAttribute("data-end-time")).getTime();
        const now = new Date().getTime();
        if (endTime - now < 0) {
            disableAuctionButtons();
        }
    }

    updateCountdown();
    checkAuctionStatus();
    setInterval(updateCountdown, 1000);

    // Change main image
    function changeMainImage(src) {
        document.getElementById('mainImage').src = src;
    }

    
// Toggle watchlist (persist to DB via /watchlist APIs)
let __watchlisted = IS_WATCHLISTED === true;

// Initialize icon
(function initWatchlistIcon() {
    const icon = document.getElementById('watchlist-icon');
    if (!icon) return;
    icon.textContent = __watchlisted ? '★' : '☆';
})();

async function toggleWatchlist() {
    if (!IS_AUTH) return window.location.href = '/login';
    if (!AUCTION_ID) return alert('Không tìm thấy phiên đấu giá.');

    const icon = document.getElementById('watchlist-icon');
    const before = __watchlisted;

    try {
        const url = before ? `/watchlist/${AUCTION_ID}/delete` : `/watchlist/${AUCTION_ID}`;
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
        });
        const data = await res.json().catch(() => ({}));

        if (!res.ok || !data.success) {
            throw new Error(data.message || 'Thao tác yêu thích thất bại');
        }

        __watchlisted = !before;
        if (icon) icon.textContent = __watchlisted ? '★' : '☆';
    } catch (err) {
        // revert UI if failed
        __watchlisted = before;
        if (icon) icon.textContent = __watchlisted ? '★' : '☆';
        alert(err?.message || 'Thao tác yêu thích thất bại');
    }
}

    function setAutoBid(event) {
        event.preventDefault();
        if (!IS_AUTH) return window.location.href = '/login';
        if (!AUCTION_ID) return alert('Không tìm thấy phiên đấu giá.');

        const max_amount = Number(document.getElementById('autoBidMax')?.value || 0);
        if (!max_amount || max_amount <= 0) return alert('Vui lòng nhập max hợp lệ.');

        fetch(`/auctions/${AUCTION_ID}/auto-bid`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ max_amount })
        })
        .then(r => r.json().catch(() => ({})).then(d => ({ ok: r.ok, d })))
        .then(({ ok, d }) => {
            if (!ok || !d.success) return alert(d.message || d.error || 'Lưu auto-bid thất bại');
            if (d.note) alert(d.note);
            window.location.reload();
        })
        .catch(() => alert('Lưu auto-bid thất bại'));
    }

    // Ask question with login check
    function askQuestion(event, productId) {
        event.preventDefault();

        // Check authentication
        if (!IS_AUTH) {
            openLoginModal();
            return;
        }

        const question = document.getElementById('questionText').value.trim();
        if (!question) {
            alert('Vui lòng nhập câu hỏi');
            return;
        }

        fetch(`/api/products/${productId}/questions`, {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            credentials: 'same-origin',
            body: JSON.stringify({ question })
        })
        .then(r => r.json().catch(() => ({})).then(d => ({ ok: r.ok, d })))
        .then(({ ok, d }) => {
            if (!ok || !d.success) {
                return alert(d.message || d.error || 'Gửi câu hỏi thất bại');
            }
            alert('Câu hỏi đã được gửi. Chúng tôi sẽ trả lời sớm.');
            document.getElementById('questionText').value = '';
            // Reload để hiện câu hỏi mới
            setTimeout(() => window.location.reload(), 1000);
        })
        .catch(err => {
            console.error(err);
            alert('Gửi câu hỏi thất bại');
        });
    }

    function openLoginModal() {
        document.getElementById('loginModal').classList.remove('hidden');
    }

    function closeLoginModal() {
        document.getElementById('loginModal').classList.add('hidden');
    }

    // Close modal when clicking outside
    document.getElementById('loginModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeLoginModal();
        }
    });

    function rejectBidder(bidderId, auctionId) {
        if (!confirm('Bạn có chắc muốn từ chối người này không?')) return;
        fetch(`/seller/auctions/${auctionId}/block-bidder`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ bidderId: bidderId })
        })
        .then(r => r.json().catch(() => ({})))
        .then(d => {
            if (!d.success) return alert(d.message || 'Từ chối thất bại');
            alert('Đã từ chối thành công!');
            window.location.reload();
        })
        .catch(() => alert('Từ chối thất bại'));
    }
</script>
</body>