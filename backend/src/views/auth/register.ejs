<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký</title>
    <link rel="stylesheet" href="/css/style.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .register-wrapper {
            display: flex;
            justify-content: center;
            padding: 60px 0;
        }

        .register-card {
            width: 960px;
            background: #fff;
            border-radius: 22px;
            padding: 50px 70px;
            box-shadow: rgba(0,0,0,0.05) 0 4px 20px;
            display: grid;
            grid-template-columns: 2fr 1.2fr;
            column-gap: 40px;
        }

        .register-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }

        .avatar-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e0e0e0;
        }

        .register-title-block h2 {
            margin: 0 0 6px 0;
            font-size: 26px;
            font-weight: 700;
            color: #333;
        }

        .register-title-block p {
            margin: 0;
            font-size: 13px;
            color: #777;
        }

        .register-title-block a {
            color: #00a8e8;
            text-decoration: none;
            font-weight: 600;
        }

        .register-title-block a:hover {
            text-decoration: underline;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            column-gap: 18px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            font-size: 14px;
            display: block;
            margin-bottom: 6px;
            color: #444;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 11px 13px;
            border-radius: 8px;
            border: 1px solid #cfcfcf;
            outline: none;
            font-size: 14px;
        }

        input:focus {
            border-color: #00b4d8;
        }

        .text-muted {
            font-size: 12px;
            color: #777;
            margin-top: -8px;
            margin-bottom: 10px;
            display: block;
        }

        .show-password-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 6px 0 14px 0;
        }

        .show-password-row input {
            width: auto;
        }

        .show-password-row label {
            margin: 0;
            font-size: 13px;
            color: #444;
        }

        .captcha-box {
            border: 1px solid #d3d3d3;
            border-radius: 6px;
            padding: 10px 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 6px;
        }

        .captcha-left {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: #444;
        }

        .captcha-left input {
            width: auto;
        }

        .captcha-right {
            font-size: 11px;
            color: #999;
            text-align: right;
        }

        .footer-row {
            margin-top: 26px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .footer-row a {
            font-size: 13px;
            color: #444;
            text-decoration: none;
        }

        .footer-row a:hover {
            text-decoration: underline;
        }

        .btn-register {
            width: 160px;
            padding: 12px 0;
            border-radius: 30px;
            border: none;
            font-size: 15px;
            background: #d7d7d7;
            cursor: pointer;
        }

        .btn-register:hover {
            background: #c2c2c2;
        }

        .register-illustration {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .shape-placeholder {
            width: 230px;
            height: 230px;
            border: 2px solid #000;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #555;
        }

        @media (max-width: 960px) {
            .register-card {
                grid-template-columns: 1fr;
                row-gap: 30px;
                padding: 40px 24px;
            }

            .register-wrapper {
                padding: 30px 10px;
            }

            .register-illustration {
                display: none;
            }
        }
    </style>
</head>
<body>

    <%- include("../partials/navbar"); %>

    <div class="register-wrapper">
        <div class="register-card">

            <div>
                <div class="register-header">
                    <div class="avatar-circle"></div>
                    <div class="register-title-block">
                        <h2>Đăng ký</h2>
                        <p>
                            Bạn đã có tài khoản chưa?
                            <a href="/login">đăng nhập</a>
                        </p>
                    </div>
                </div>

                        <% if (typeof error !== 'undefined' && error) { %>
            <p style="color:#d00; margin-bottom: 12px;"><%= error %></p>
        <% } %>

<form action="/auth/register" method="POST" id="registerForm">
                    <!-- input ẩn để gửi full name cho backend -->
                    <input type="hidden" name="name" id="fullName" />

                    <div class="form-row">
                        <div class="form-group">
                            <label>Họ</label>
                            <input type="text" id="lastName" required />
                        </div>
                        <div class="form-group">
                            <label>Tên</label>
                            <input type="text" id="firstName" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" required />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Mật khẩu</label>
                            <input type="password" name="password" id="password" required />
                        </div>
                        <div class="form-group">
                            <label>Nhập lại mật khẩu</label>
                            <input type="password" id="confirmPassword" required />
                        </div>
                    </div>

                    <span class="text-muted">
                        Sử dụng 8 ký tự trở lên kết hợp chữ cái, số và ký hiệu
                    </span>

                    <div class="show-password-row">
                        <input type="checkbox" id="togglePassword" />
                        <label for="togglePassword">Hiện mật khẩu</label>
                    </div>

                    <div class="captcha-box">
                        <div class="captcha-left">
                            <input type="checkbox" />
                            <span>Não sou um robô</span>
                        </div>
                        <div class="captcha-right">
                            reCAPTCHA<br />Privacy • Terms
                        </div>
                    </div>

                    <div class="footer-row">
                        <a href="/login">đăng nhập thay thế</a>
                        <button type="submit" class="btn-register">Đăng ký</button>
                    </div>
                </form>
            </div>

            <div class="register-illustration">
                <div class="shape-placeholder">
                    Hình minh họa theo Figma
                </div>
            </div>

        </div>
    </div>

    <script>
        // Gộp Họ + Tên vào field name trước khi submit
        const form = document.getElementById('registerForm');
        const firstNameInput = document.getElementById('firstName');
        const lastNameInput = document.getElementById('lastName');
        const fullNameInput = document.getElementById('fullName');
        const passwordInput = document.getElementById('password');
        const confirmPasswordInput = document.getElementById('confirmPassword');

        form.addEventListener('submit', function (e) {
            // đơn giản: check lại mật khẩu trùng nhau
            if (passwordInput.value !== confirmPasswordInput.value) {
                e.preventDefault();
                alert('Mật khẩu nhập lại không khớp.');
                return;
            }

            fullNameInput.value = (lastNameInput.value + ' ' + firstNameInput.value).trim();
        });

        // Hiện / ẩn mật khẩu
        const togglePassword = document.getElementById('togglePassword');
        togglePassword.addEventListener('change', function () {
            const type = this.checked ? 'text' : 'password';
            passwordInput.type = type;
            confirmPasswordInput.type = type;
        });
    </script>
</body>
</html>
