<% layout("layouts/main") %>

<section class="min-h-[72vh] flex items-center justify-center py-10">
  <div class="max-w-3xl w-full bg-white/95 shadow-xl shadow-slate-200/70 rounded-2xl border border-slate-100 p-6 sm:p-8">
    <div class="flex flex-col md:flex-row gap-8">
      <!-- Intro / illustration -->
      <div class="space-y-4 md:w-5/12">
        <div class="inline-flex items-center gap-2 rounded-full bg-teal-50 px-3 py-1 text-xs font-medium text-teal-700 border border-teal-100">
          <span>Welcome to</span>
          <span class="font-semibold">PTUDW Auction</span>
        </div>
        <h1 class="text-2xl font-semibold text-slate-900">
          Tạo tài khoản mới
        </h1>
        <p class="text-sm text-slate-500 leading-relaxed">
          Đăng ký để bắt đầu tham gia đặt giá, theo dõi sản phẩm yêu thích và quản lý lịch sử đấu giá của bạn.
        </p>

        <!-- Placeholder illustration/banner -->
        <div class="mt-4 w-full aspect-video rounded-2xl bg-gradient-to-tr from-teal-500 via-sky-500 to-indigo-500 flex items-center justify-center text-white text-sm font-medium shadow-md">
          <img src="/images/logo.png" alt="Logo" class="h-32 w-auto object-contain" />
        </div>

        <p class="mt-4 text-xs text-slate-500">
          Đã có tài khoản?
          <a href="/login" class="font-semibold text-teal-600 hover:text-teal-700">Đăng nhập</a>
        </p>
      </div>

      <!-- Form -->
      <div class="md:w-7/12">
        <% if (typeof error !== "undefined" && error) { %>
          <div class="mb-4 text-sm px-3 py-2 rounded-lg border border-rose-200 bg-rose-50 text-rose-700">
            <%= error %>
          </div>
        <% } %>

        <form action="/auth/register" method="POST" id="registerForm" class="space-y-4">
          <!-- hidden full name for backend -->
          <input type="hidden" name="name" id="fullName" />

          <!-- Name -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="space-y-1">
              <label for="lastName" class="text-xs font-medium text-slate-600">Họ</label>
              <input
                id="lastName"
                type="text"
                required
                class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500"
              />
            </div>
            <div class="space-y-1">
              <label for="firstName" class="text-xs font-medium text-slate-600">Tên</label>
              <input
                id="firstName"
                type="text"
                required
                class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500"
              />
            </div>
          </div>

          <!-- Email -->
          <div class="space-y-1">
            <label for="email" class="text-xs font-medium text-slate-600">Email</label>
            <input
              id="email"
              type="email"
              name="email"
              required
              class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500"
            />
          </div>

          <!-- Password + confirm -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="space-y-1">
              <label for="password" class="text-xs font-medium text-slate-600">Mật khẩu</label>
              <input
                id="password"
                type="password"
                name="password"
                minlength="6"
                required
                class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500"
              />
            </div>
            <div class="space-y-1">
              <label for="confirmPassword" class="text-xs font-medium text-slate-600">Xác nhận mật khẩu</label>
              <input
                id="confirmPassword"
                type="password"
                minlength="6"
                required
                class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500"
              />
            </div>
          </div>

          <!-- Show password -->
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <input id="togglePassword" type="checkbox" class="rounded border-slate-300 text-teal-600 focus:ring-teal-500/70" />
            <label for="togglePassword">Hiển thị mật khẩu</label>
          </div>

          <!-- Simple arithmetic captcha -->
          <div class="mt-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
            <label class="text-xs text-slate-600">Captcha: Vui lòng nhập kết quả</label>
            <div class="mt-2 flex items-center gap-3">
              <div class="p-2 rounded bg-white border text-sm font-medium" id="captchaQuestion"><%= captchaQuestion || '' %></div>
              <input type="text" name="captcha" id="captchaInput" required class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-teal-500/60 focus:border-teal-500" />
              <button type="button" id="refreshCaptcha" class="text-xs px-2 py-1 bg-slate-100 rounded">Làm mới</button>
            </div>
            <div class="text-[10px] text-slate-400 mt-1">Captcha đơn giản (toán học) để tránh bot tự động.</div>
          </div>

          <!-- Submit -->
          <div class="flex items-center justify-between pt-1">
            <a href="/login" class="text-xs text-teal-600 hover:text-teal-700">Đăng nhập thay thế</a>
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-teal-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500"
            >
              Đăng ký
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const form = document.getElementById('registerForm');
  const firstNameInput = document.getElementById('firstName');
  const lastNameInput = document.getElementById('lastName');
  const fullNameInput = document.getElementById('fullName');
  const passwordInput = document.getElementById('password');
  const confirmPasswordInput = document.getElementById('confirmPassword');
  const togglePassword = document.getElementById('togglePassword');

  if (form && firstNameInput && lastNameInput && fullNameInput) {
    form.addEventListener('submit', function() {
      fullNameInput.value = (lastNameInput.value + ' ' + firstNameInput.value).trim();
    });
  }

  // Refresh captcha via simple fetch to endpoint that returns new question
  const refreshBtn = document.getElementById('refreshCaptcha');
  const captchaQuestionEl = document.getElementById('captchaQuestion');
  if (refreshBtn && captchaQuestionEl) {
    refreshBtn.addEventListener('click', async function() {
      try {
        const res = await fetch('/auth/captcha');
        if (!res.ok) throw new Error('Failed');
        const json = await res.json();
        captchaQuestionEl.textContent = json.question || '';
      } catch (e) {
        console.warn('refresh captcha failed', e);
      }
    });
  }

  if (togglePassword && passwordInput && confirmPasswordInput) {
    togglePassword.addEventListener('change', function() {
      const type = this.checked ? 'text' : 'password';
      passwordInput.type = type;
      confirmPasswordInput.type = type;
    });
  }
})();
</script>
