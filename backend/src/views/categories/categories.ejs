<% 
  const fmtPrice = (p) => {
    const n = Number(p);
    return Number.isFinite(n) ? n.toLocaleString('vi-VN') : (p || '0');
  };
  const imgSrc = (images, productId) => {
    // Ưu tiên images[0]
    const img = Array.isArray(images) && images.length ? images[0] : null;
    if (img && /^https?:\/\//i.test(img)) return img;
    if (img && img.startsWith('/uploads')) return img;
    if (img && img.includes('/')) {
      return '/uploads/' + img.replace(/^\/+/, '');
    }
    if (img && productId && !img.includes('/')) {
      return `/uploads/products/${productId}/${img}`;
    }
    // Fallback: dùng 0.jpg từ folder product
    if (productId) {
      return `/uploads/products/${productId}/0.jpg`;
    }
    return '/images/placeholder.svg';
  };
  const fmtDate = (d) => {
    if (!d) return '';
    try { return new Date(d).toLocaleString('vi-VN'); } catch(e) { return String(d); }
  };

  const catList = Array.isArray(categories) ? categories : [];
%>

<main>
  <section class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold mb-1"><%= title || 'Danh mục' %></h1>
      <p class="text-gray-600">Chọn danh mục để xem phiên đấu giá tương ứng</p>
    </div>

    <div class="flex items-center gap-2">
      <label for="catSelect" class="text-sm text-gray-700 font-medium">Danh mục:</label>
      <select id="catSelect" class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
        <option value="">Tất cả</option>
        <% catList.forEach(c => { %>
          <option value="<%= c.slug %>" <%= (categorySlug === c.slug) ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
  </section>

  <section id="auctionGrid" class="grid gap-6 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
    <% if (Array.isArray(auctions) && auctions.length) { %>
      <% auctions.forEach(a => { %>
        <article class="auction-item rounded-lg overflow-hidden bg-white shadow"
                 data-price="<%= a.current_price || 0 %>"
                 data-time="<%= a.end_time ? new Date(a.end_time).getTime() : 0 %>">
          <div class="card-image-wrap" style="min-height:176px;display:flex;align-items:center;justify-content:center;overflow:hidden">
            <a href="/auctions/<%= a.id %>" class="w-full h-full block" aria-label="<%= a.title || 'Sản phẩm' %>">
              <img src="<%= imgSrc(a.images, a.product_id) %>" alt="<%= a.title || 'No title' %>" style="width:100%;height:100%;object-fit:cover">
            </a>
          </div>

          <div class="p-4">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium">
                <a href="/auctions/<%= a.id %>" class="hover:text-teal-600"><%= a.title || 'Untitled' %></a>
              </h3>
            </div>

            <p class="text-sm text-gray-800 font-semibold mt-2">
              Giá hiện tại: <span class="text-teal-600"><%= fmtPrice(a.current_price) %> VNĐ</span>
            </p>
            <p class="text-sm text-gray-500 mt-1">Kết thúc: <%= fmtDate(a.end_time) %></p>

            <div class="mt-4">
              <a href="/product/<%= a.product_id %>" class="block text-center px-3 py-2 border rounded text-sm text-gray-700 hover:bg-gray-50">Xem chi tiết</a>
            </div>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <div class="col-span-full bg-white rounded-lg p-6 text-center text-gray-600 shadow">
        Chưa có phiên đấu giá trong danh mục này.
      </div>
    <% } %>
  </section>

  <% if (pagination && pagination.pages && pagination.pages.length) { %>
    <nav class="py-6 flex justify-center items-center gap-2">
      <% if (pagination.prev) { %>
        <a href="<%= pagination.prev %>" class="w-10 h-10 flex items-center justify-center rounded-full border text-gray-600 hover:bg-gray-50" aria-label="Trang trước">‹</a>
      <% } %>
      <% pagination.pages.forEach(p => { %>
        <a href="<%= p.url %>" class="w-10 h-10 flex items-center justify-center rounded-full border <%= p.current ? 'bg-black text-white font-semibold' : 'text-gray-600 hover:bg-gray-50' %>"><%= p.num %></a>
      <% }) %>
      <% if (pagination.next) { %>
        <a href="<%= pagination.next %>" class="w-10 h-10 flex items-center justify-center rounded-full border text-gray-600 hover:bg-gray-50" aria-label="Trang sau">›</a>
      <% } %>
    </nav>
  <% } %>
</main>

<script>
(function(){
  const catSelect = document.getElementById('catSelect');
  if (!catSelect) return;
  catSelect.addEventListener('change', (e) => {
    const slug = e.target.value;
    const url = slug ? `/categories/${slug}` : `/categories`;
    window.location.href = url;
  });
})();
</script>