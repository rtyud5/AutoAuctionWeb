<% 
  // helpers
  const fmtPrice = (p) => {
    const n = Number(p);
    return Number.isFinite(n) ? n.toLocaleString('vi-VN') : (p || '0');
  };
  const imgSrc = (img) => {
    if (!img) return '/images/placeholder.svg';
    return (/^https?:\/\//i).test(img) ? img : ('/images/' + img.replace(/^\/+/, ''));
  };
  const fmtDate = (d) => {
    if (!d) return '';
    try { return new Date(d).toLocaleString('vi-VN'); } catch(e) { return String(d); }
  };

  // choose highlighted item: prefer is_new, else first
  let highlightedId = null;
  if (Array.isArray(auctions) && auctions.length) {
    const newItem = auctions.find(x => x.is_new);
    highlightedId = (newItem && newItem.id) ? newItem.id : auctions[0].id;
  }
%>

<style>
  .card-highlight {
    background: linear-gradient(135deg,#fff1f3 0%,#ffe4ea 60%);
    border: 1px solid rgba(219,39,119,0.12);
    box-shadow: 0 10px 24px rgba(219,39,119,0.08);
    transform: translateY(-6px);
  }
  .badge-new {
    background:#db2777;color:#fff;font-weight:700;font-size:12px;padding:4px 8px;border-radius:999px;
  }
  .card-image-wrap{min-height:176px;display:flex;align-items:center;justify-content:center;overflow:hidden}
  .card-image-wrap img{width:100%;height:100%;object-fit:cover}
  .card-title a{color:#0f172a;text-decoration:none}
  .card-meta{color:#6b7280;font-size:13px}
</style>

<main>
  <section class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold mb-1"><%= title || 'Thời trang' %></h1>
      <p class="text-gray-600">Các phiên đấu giá trong danh mục "<%= title || category || 'Thời trang' %>"</p>
    </div>

    <!-- Sorting dropdown -->
    <div class="flex items-center gap-2">
      <label for="sortSelect" class="text-sm text-gray-700 font-medium">Sắp xếp theo:</label>
      <select id="sortSelect" class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
        <option value="default">Mặc định</option>
        <option value="price-asc">Giá: Thấp → Cao</option>
        <option value="price-desc">Giá: Cao → Thấp</option>
        <option value="time-asc">Thời gian: Sớm → Muộn</option>
        <option value="time-desc">Thời gian: Muộn → Sớm</option>
      </select>
    </div>
  </section>

  <section id="auctionGrid" class="grid gap-6 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
    <% if (Array.isArray(auctions) && auctions.length) { %>
      <% auctions.forEach(a => { 
           const isHighlighted = (a.id === highlightedId);
      %>
        <article class="auction-item rounded-lg overflow-hidden transition-shadow duration-200 <%= isHighlighted ? 'card-highlight' : 'bg-white shadow' %>"
                 data-price="<%= a.current_price || 0 %>"
                 data-time="<%= a.end_time ? new Date(a.end_time).getTime() : 0 %>">
          <div class="card-image-wrap">
            <a href="/auctions/<%= a.id %>" class="w-full h-full block" aria-label="<%= a.title || 'Sản phẩm' %>">
              <img src="<%= imgSrc(a.image) %>" alt="<%= a.title || 'No title' %>">
            </a>
          </div>

          <div class="p-4">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium card-title">
                <a href="/auctions/<%= a.id %>" class="hover:text-teal-600"><%= a.title || 'Untitled' %></a>
              </h3>
              <% if (isHighlighted) { %>
                <span class="badge-new ml-2">New</span>
              <% } %>
            </div>

            <p class="text-sm text-gray-800 font-semibold mt-2">
              Giá hiện tại: <span class="text-teal-600"><%= fmtPrice(a.current_price) %> VNĐ</span>
            </p>
            <p class="card-meta mt-1">Bidder cao nhất: <%= a.top_bidder ? (a.top_bidder.maskedName || a.top_bidder.name) : '---' %></p>
            <p class="card-meta">Kết thúc: <%= fmtDate(a.end_time) %></p>

            <div class="mt-4 flex items-center gap-2">
              <a href="/auctions/<%= a.id %>" class="px-3 py-1 border rounded text-sm text-gray-700 hover:bg-gray-50">Xem chi tiết</a>
              <form action="/auctions/<%= a.id %>/buy" method="post" class="ml-auto">
                <button class="px-3 py-1 bg-teal-500 text-white rounded text-sm hover:bg-teal-600" type="submit">Mua ngay</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    <% } else { %>
      <div class="col-span-full bg-white rounded-lg p-6 text-center text-gray-600 shadow">
        Chưa có phiên đấu giá trong danh mục này.
      </div>
    <% } %>
  </section>
</main>

<!-- Footer with contact info and pagination -->
<footer class="mt-12">
  <!-- Pagination -->
  <nav class="py-6 flex justify-center items-center gap-2">
    <% if (pagination && pagination.pages && pagination.pages.length > 0) { %>
      <% if (pagination.prev) { %>
        <a href="<%= pagination.prev %>" class="w-10 h-10 flex items-center justify-center rounded-full border text-gray-600 hover:bg-gray-50" aria-label="Trang trước">‹</a>
      <% } %>
      <% pagination.pages.forEach(p => { %>
        <a href="<%= p.url %>" class="w-10 h-10 flex items-center justify-center rounded-full border <%= p.current ? 'bg-black text-white font-semibold' : 'text-gray-600 hover:bg-gray-50' %>"><%= p.num %></a>
      <% }) %>
      <% if (pagination.next) { %>
        <a href="<%= pagination.next %>" class="w-10 h-10 flex items-center justify-center rounded-full border text-gray-600 hover:bg-gray-50" aria-label="Trang sau">›</a>
      <% } %>
    <% } else { %>
      <!-- Fallback demo -->
      <button class="w-10 h-10 flex items-center justify-center rounded-full border bg-black text-white font-semibold">1</button>
    <% } %>
  </nav>

  <!-- Contact Info Section -->
  <section class="bg-white shadow-md rounded-2xl px-8 py-12 mt-8">
    <div class="container mx-auto flex flex-col md:flex-row items-center gap-8">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <img src="/images/logo.png" alt="UOE Logo" class="w-32 h-auto">
      </div>

      <!-- Contact Details -->
      <div class="text-gray-800 flex-1">
        <h3 class="text-xl font-semibold mb-4">THÔNG TIN LIÊN HỆ</h3>
        <p class="mb-1"><strong>Hotline:</strong> 0359988494</p>
        <p class="mb-1"><strong>Email:</strong> <a href="mailto:tavanduc298@gmail.com" class="text-teal-600 hover:underline">tavanduc298@gmail.com</a></p>
        <p class="mb-1"><strong>Địa chỉ:</strong> 227 Nguyễn Văn Cừ, Quận 5, TP.HCM</p>
      </div>
    </div>
  </section>
</footer>

<script>
(function() {
  const sortSelect = document.getElementById('sortSelect');
  const grid = document.getElementById('auctionGrid');
  if (!sortSelect || !grid) return;

  sortSelect.addEventListener('change', (e) => {
    const value = e.target.value;
    const items = Array.from(grid.querySelectorAll('.auction-item'));
    if (items.length === 0) return;

    let sorted = [...items];
    switch(value) {
      case 'price-asc':
        sorted.sort((a, b) => parseFloat(a.dataset.price) - parseFloat(b.dataset.price));
        break;
      case 'price-desc':
        sorted.sort((a, b) => parseFloat(b.dataset.price) - parseFloat(a.dataset.price));
        break;
      case 'time-asc':
        sorted.sort((a, b) => parseFloat(a.dataset.time) - parseFloat(b.dataset.time));
        break;
      case 'time-desc':
        sorted.sort((a, b) => parseFloat(b.dataset.time) - parseFloat(a.dataset.time));
        break;
      default:
        break;
    }

    sorted.forEach(item => grid.appendChild(item));
  });
})();
</script>