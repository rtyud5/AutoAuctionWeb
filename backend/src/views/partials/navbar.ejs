            type="submit"
            class="absolute inset-y-0 right-0 flex items-center justify-center mr-1 rounded-full w-6 h-6 bg-teal-500 text-white hover:bg-teal-600 focus:outline-none"
          >
            🔍
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Scripts: Category dropdown + Auth state -->
  <script>
    (function () {
      // ===== CATEGORY DROPDOWN =====
      const CategoryDropdown = {
        toggleBtn: null,
        panel: null,
        arrow: null,
        mobileToggle: null,

        init() {
          this.toggleBtn = document.getElementById("catToggle");
          this.panel = document.getElementById("catPanel");
          this.arrow = document.getElementById("catArrow");
          this.mobileToggle = document.getElementById("catToggleMobile");
          if (!this.toggleBtn || !this.panel) return;
          this.bindEvents();
        },

        show() {
          this.panel.classList.remove("hidden");
          if (this.arrow) {
            this.arrow.style.transform = "rotate(180deg)";
          }
        },

        hide() {
          this.panel.classList.add("hidden");
          if (this.arrow) {
            this.arrow.style.transform = "rotate(0deg)";
          }
        },

        isVisible() {
          return !this.panel.classList.contains("hidden");
        },

        toggleDropdown() {
          if (this.isVisible()) {
            this.hide();
          } else {
            this.show();
          }
        },

        bindEvents() {
          // Desktop toggle
          this.toggleBtn.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            this.toggleDropdown();
          });

          // Mobile toggle uses same panel
          if (this.mobileToggle) {
            this.mobileToggle.addEventListener("click", (e) => {
              e.preventDefault();
              e.stopPropagation();
              this.toggleDropdown();
            });
          }

          // Close on Escape
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && this.isVisible()) {
              this.hide();
            }
          });

          // Close on outside click
          document.addEventListener("click", (e) => {
            if (
              !this.toggleBtn.contains(e.target) &&
              !this.panel.contains(e.target) &&
              (!this.mobileToggle || !this.mobileToggle.contains(e.target))
            ) {
              this.hide();
            }
          });
        },
      };

      // ===== AUTH AREA (hiển thị guest / user) =====
      const UserAuth = {
        init() {
          const authArea = document.getElementById("auth-area");
          const guest = document.getElementById("auth-guest");
          const user = document.getElementById("auth-user");
          const userMenu = document.getElementById("user-menu");

          if (!authArea || !guest || !user) return;

          const isLoggedIn = document.body.dataset.user === "true";

          if (isLoggedIn) {
            guest.classList.add("hidden");
            user.classList.remove("hidden");
          } else {
            guest.classList.remove("hidden");
            user.classList.add("hidden");
          }

          // Toggle user dropdown menu
          user.addEventListener("click", (e) => {
            e.stopPropagation();
            if (userMenu) {
              userMenu.classList.toggle("hidden");
            }
          });

          document.addEventListener("click", () => {
            if (userMenu && !userMenu.classList.contains("hidden")) {
              userMenu.classList.add("hidden");
            }
          });
        },
      };

      // === Initialize All Modules ===
      const init = () => {
        CategoryDropdown.init();
        UserAuth.init();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    })();
  </script>
</nav>
