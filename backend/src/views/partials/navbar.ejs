  <!-- Mobile menu: categories shortcut & search -->
  <div class="md:hidden border-t border-teal-400/50 bg-teal-500/95">
    <div class="max-w-6xl mx-auto px-4 py-2 flex items-center justify-between gap-3">
      <button
        id="catToggleMobile"
        type="button"
        class="flex items-center gap-1 text-sm text-white hover:text-slate-100"
      >
        <span>Danh mục</span>
        <span aria-hidden="true">▾</span>
      </button>
      <form action="/search" method="get" class="flex-1">
        <div class="relative">
          <input
            type="text"
            name="q"
            placeholder="Search..."
            class="w-full rounded-full bg-white/95 text-slate-800 pl-3 pr-9 py-1.5 text-xs shadow-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-300"
          />
