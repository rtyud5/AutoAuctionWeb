<nav style="
    width: 100%;
    height: 65px;
    background: #00C2D1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    font-family: 'Inter', sans-serif;
">
    <!-- Left: Logo + Menu -->
    <div style="display: flex; align-items: center; gap: 28px;">
        
        <!-- Logo -->
        <a href="/" style="text-decoration: none;">
            <img src="/images/logo.png" alt="logo" style="height: 38px;">
        </a>

        <!-- Menu -->
        <div style="display: flex; align-items: center; gap: 14px; font-size: 15px;">
            <a href="/" style="color: white; text-decoration: none;">Trang chủ</a>

            <div style="position: relative;">
                <a href="/list" style="color: white; text-decoration: none;">
                    danh sách danh mục ▼
                </a>
            </div>

            <div style="position: relative;">
                <a href="/setting" style="color: white; text-decoration: none;">
                    Cài đặt Profile
                </a>
            </div>
        </div>
    </div>

    <!-- Right: Search + Auth -->
    <div style="display: flex; align-items: center; gap: 20px;">

        <!-- Search box -->
        <div style="
            position: relative;
            background: rgba(255,255,255,0.4);
            padding: 6px 16px;
            border-radius: 28px;
            display: flex;
            align-items: center;
            width: 330px;
        ">
            <input 
                type="text" 
                placeholder="Search..."
                style="
                    width: 100%;
                    border: none;
                    outline: none;
                    background: transparent;
                    font-size: 14px;
                    color: #044;
                "
            />
            <img 
                src="https://cdn-icons-png.flaticon.com/128/622/622669.png"
                alt="search"
                style="height: 20px; margin-left: 8px; opacity: 0.7;"
            >
        </div>
    </div>

    <!-- Auth Zone -->
    <div id="auth-area" style="display: flex; align-items: center; gap: 20px;">

        <!-- Khi chưa đăng nhập -->
        <div id="auth-guest">
            <a href="/login" style="color: white; text-decoration: none; font-size: 15px;">
                Sign In
            </a>
            <a href="/register" style="color: white; text-decoration: none; font-size: 15px;">
                Register
            </a>
        </div>

        <!-- Khi đã đăng nhập -->
        <div id="auth-user" style="display: none; position: relative; cursor: pointer;">

            <!-- Avatar + arrow -->
            <div style="display: flex; align-items: center; gap: 8px;">
                <img src="/images/user-avatar.png" 
                    style="height: 38px; width: 38px; border-radius: 50%; object-fit: cover;">
                <span style="color: white; font-size: 14px;">▼</span>
            </div>

            <!-- Dropdown menu -->
            <div id="user-menu" 
                style="
                    position: absolute;
                    top: 48px;
                    right: 0;
                    background: white;
                    border-radius: 8px;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
                    width: 160px;
                    display: none;
                    z-index: 999;
                ">
                <a href="/setting" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    Cài đặt Profile
                </a>

                <a href="/logout" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    Đăng xuất
                </a>
            </div>

        </div>

    </div>

</nav>

<script>
    // Ví dụ kiểm tra login (bạn đổi thành logic thật)
    const isLoggedIn = true; // hoặc req.session.user != null

    const guestArea = document.getElementById("auth-guest");
    const userArea = document.getElementById("auth-user");
    const menu = document.getElementById("user-menu");

    // Nếu đã đăng nhập → ẩn guest, hiện user
    if (isLoggedIn) {
        guestArea.style.display = "none";
        userArea.style.display = "flex";
    }

    // Toggle menu khi bấm avatar
    userArea.onclick = () => {
        menu.style.display = menu.style.display === "block" ? "none" : "block";
    };

    // Click ra ngoài thì ẩn menu
    document.addEventListener("click", function (e) {
        if (!userArea.contains(e.target)) {
            menu.style.display = "none";
        }
    });
</script>

