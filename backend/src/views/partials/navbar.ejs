<nav style="
    width: 100%;
    height: 65px;
    background: #00C2D1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    font-family: 'Inter', sans-serif;
">
    <!-- Left: Logo + Menu -->
    <div style="display: flex; align-items: center; gap: 28px;">
        
        <!-- Logo -->
        <a href="/" style="text-decoration: none;">
            <img src="/images/logo.png" alt="logo" style="height: 38px;">
        </a>

        <!-- Menu -->
        <div style="display: flex; align-items: center; gap: 14px; font-size: 15px;">
            <a href="/" style="color: white; text-decoration: none;">Trang chủ</a>

            <!-- Category dropdown -->
            <div style="position: relative;">
                <button id="catToggle" type="button" aria-expanded="false" aria-controls="catPanel"
                  style="background:transparent;border:none;color:white;cursor:pointer;font-size:15px;padding:0;display:flex;align-items:center;gap:6px;">
                    <span>danh sách danh mục</span>
                    <span id="catArrow" aria-hidden="true" style="display:inline-block;font-size:20px;line-height:1;transform:translateY(1px);transition:transform .18s;transform-origin:center;">▾</span>
                </button>

                <!-- dropdown panel (hidden by default) -->
                <div id="catPanel" class="hidden absolute top-9 left-0 min-w-[160px] bg-blue-100 text-blue-800 rounded-lg shadow-md overflow-hidden z-60">
                    <a href="/electronics" class="block px-4 py-3 border-b border-blue-200 hover:bg-blue-200">
                        Điện tử
                    </a>
                    <a href="/fashion" class="block px-4 py-3 hover:bg-blue-200">
                        Thời trang
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Search + Auth -->
    <div style="display: flex; align-items: center; gap: 20px;">

        <!-- Search box -->
        <div style="
            position: relative;
            background: rgba(255,255,255,0.4);
            padding: 6px 16px;
            border-radius: 28px;
            display: flex;
            align-items: center;
            width: 330px;
        ">
            <input 
                type="text" 
                placeholder="Search..."
                style="
                    width: 100%;
                    border: none;
                    outline: none;
                    background: transparent;
                    font-size: 14px;
                    color: #044;
                "
            />
            <img 
                src="https://cdn-icons-png.flaticon.com/128/622/622669.png"
                alt="search"
                style="height: 20px; margin-left: 8px; opacity: 0.7;"
            >
        </div>
    </div>

    <!-- Auth Zone -->
    <div id="auth-area" style="display: flex; align-items: center; gap: 20px;">

        <!-- Khi chưa đăng nhập -->
        <div id="auth-guest">
            <a href="/login" style="color: white; text-decoration: none; font-size: 15px;">
                Sign In
            </a>
            <a href="/register" style="color: white; text-decoration: none; font-size: 15px;">
                Register
            </a>
        </div>

        <!-- Khi đã đăng nhập -->
        <div id="auth-user" style="display: none; position: relative; cursor: pointer;">

            <!-- Avatar + arrow -->
            <div style="display: flex; align-items: center; gap: 8px;">
                <img src="/images/user-avatar.png" 
                    style="height: 38px; width: 38px; border-radius: 50%; object-fit: cover;">
                <span style="color: white; font-size: 14px;">▼</span>
            </div>

            <!-- Dropdown menu -->
            <div id="user-menu" 
                style="
                    position: absolute;
                    top: 48px;
                    right: 0;
                    background: white;
                    border-radius: 8px;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.2);
                    width: 160px;
                    display: none;
                    z-index: 999;
                ">
                <a href="/setting" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    my profile
                </a>

                <a href="/review" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    my review
                </a>

                <a href="/itemHistory" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    lịch sử
                </a>

                <a href="/itemManager" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    quản lí sản phẩm
                </a>

                <a href="/auth/logout" 
                style="padding: 10px 12px; display: block; text-decoration: none; color: #333;">
                    Đăng xuất
                </a>
            </div>

        </div>

    </div>

</nav>

<script>
(function() {
  'use strict';

  // === Category Dropdown Module ===
  const CategoryDropdown = {
    init() {
      this.toggleBtn = document.getElementById('catToggle');
      this.panel = document.getElementById('catPanel');
      this.arrow = document.getElementById('catArrow');

      if (!this.toggleBtn || !this.panel || !this.arrow) {
        console.error('Category dropdown elements not found');
        return;
      }

      this.bindEvents();
      this.hide();
    },

    show() {
      this.panel.classList.remove('hidden');
      this.toggleBtn.setAttribute('aria-expanded', 'true');
      this.arrow.style.transform = 'rotate(180deg)';
    },

    hide() {
      this.panel.classList.add('hidden');
      this.toggleBtn.setAttribute('aria-expanded', 'false');
      this.arrow.style.transform = 'rotate(0deg)';
    },

    isVisible() {
      return !this.panel.classList.contains('hidden');
    },

    toggleDropdown() {
      if (this.isVisible()) {
        this.hide();
      } else {
        this.show();
      }
    },

    bindEvents() {
      // Toggle on click
      this.toggleBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        this.toggleDropdown();
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this.isVisible()) {
          this.hide();
        }
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!this.toggleBtn.contains(e.target) && !this.panel.contains(e.target)) {
          this.hide();
        }
      });
    }
  };

  // === User Authentication Module ===
  const UserAuth = {
    init() {
      // Lấy trạng thái đăng nhập từ server (res.locals)
      this.isLoggedIn = <%= (typeof isAuthenticated !== 'undefined' && isAuthenticated) ? 'true' : 'false' %>;
      this.role = "<%= typeof role !== 'undefined' ? role : 'guest' %>";

      this.guestArea = document.getElementById('auth-guest');
      this.userArea = document.getElementById('auth-user');
      this.menu = document.getElementById('user-menu');

      if (!this.guestArea || !this.userArea || !this.menu) {
        console.error('Auth elements not found');
        return;
      }

      this.updateAuthDisplay();
      if (this.isLoggedIn) {
        this.bindUserMenuEvents();
      }
    },

    updateAuthDisplay() {
      if (this.isLoggedIn) {
        this.guestArea.style.display = 'none';
        this.userArea.style.display = 'flex';
      } else {
        this.guestArea.style.display = 'flex';
        this.userArea.style.display = 'none';
      }
    },

    toggleMenu() {
      const isVisible = this.menu.style.display === 'block';
      this.menu.style.display = isVisible ? 'none' : 'block';
    },

    hideMenu() {
      this.menu.style.display = 'none';
    },

    bindUserMenuEvents() {
      // Toggle menu on avatar click
      this.userArea.addEventListener('click', (e) => {
        e.stopPropagation();
        this.toggleMenu();
      });

      // Close menu on outside click
      document.addEventListener('click', (e) => {
        if (!this.userArea.contains(e.target) && !this.menu.contains(e.target)) {
          this.hideMenu();
        }
      });

      // Close menu on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          this.hideMenu();
        }
      });
    }
  };

  // === Initialize All Modules ===
  const init = () => {
    CategoryDropdown.init();
    UserAuth.init();
  };

  // Run when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>