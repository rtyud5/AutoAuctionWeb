            class="hidden absolute top-9 left-0 min-w-[180px] rounded-lg shadow-md bg-white text-slate-800 overflow-hidden z-60"
          >
            <a href="/electronics" class="block px-4 py-3 border-b border-slate-100 hover:bg-slate-50">
              Điện tử
